                    if(txt.includes('펌웨어')||txt.includes('업그레이드')) { cause='대기화면 멈춤 → 펌웨어 업그레이드'; actionType='펌웨어 업그레이드'; }
                    else if(txt.includes('재부팅')||txt.includes('재시작')) { cause='대기화면 멈춤 → 재부팅 후 정상'; actionType='소프트웨어 리셋'; }
                    else { cause='대기화면 멈춤 → 점검 후 정상'; actionType='단순 점검'; }
                }
                else if(txt.includes('펌웨어')||txt.includes('업그레이드')) { cause='펌웨어 업그레이드 후 정상'; actionType='펌웨어 업그레이드'; }
                else if(txt.includes('재현안됨')||txt.includes('정상')||txt.includes('이상없')) { cause='현장 방문 시 현상 재현 안됨'; actionType='단순 점검'; }
                else { cause='장비 동작 이상 → 현장 점검 후 정상'; actionType='단순 점검'; }
            }

            /* cat6 - 고객문의/클레임 */
            else if(mc==='cat6'){
                if(sub.includes('로고')) { cause='로고 변경 작업 완료'; actionType='로고 변경'; }
                else if(sub.includes('Upgrade')||sub.includes('업그레이드')) {
                    if(txt.includes('펌웨어')) { cause='펌웨어 업그레이드 완료'; actionType='펌웨어 업그레이드'; }
                    else { cause='장비 업그레이드 완료'; actionType='펌웨어 업그레이드'; }
                }
                else if(sub.includes('정도관리')) { cause='정기 유지보수 점검 완료'; actionType='단순 점검'; }
                else if(sub.includes('세척')||txt.includes('세척')) { cause='장비 세척 완료'; actionType='세척'; }
                else if(sub.includes('사용방법')||sub.includes('교육')) { cause='사용법 교육/안내 완료'; actionType='단순 안내'; }
                else if(sub.includes('구매')||sub.includes('비용')||sub.includes('호환')||sub.includes('문의')) { cause='고객 문의 → 안내 완료'; actionType='단순 안내'; }
                else if(sub.includes('클레임')) { cause='고객 클레임 접수 → 현장 처리'; actionType='단순 점검'; }
                else if(sub.includes('보상판매')) { cause='보상판매/장비 교환 진행'; actionType='단순 안내'; }
                else if(sub.includes('검사필증')||sub.includes('검교정')) { cause='검사필증/검교정 발급 안내'; actionType='단순 안내'; }
                else if(sub.includes('Setup')||sub.includes('setup')) { cause='장비 설치/셋업 문의 → 안내 완료'; actionType='단순 안내'; }
                else if(sub.includes('결과지')||sub.includes('특수문자')) { cause='결과지 출력 이상 → 설정 안내'; actionType='단순 안내'; }
                else { cause='고객 문의/방문 → 안내 완료'; actionType='단순 안내'; }
            }

            /* cat8 - 노이즈/환경 */
            else if(mc==='cat8'){
                if(txt.includes('정전기')||txt.includes('매트')) { cause='정전기 환경 → 제전매트 설치'; actionType='보완재 설치'; }
                else if(txt.includes('노이즈')||txt.includes('필터')) { cause='전원 노이즈 → 필터 설치'; actionType='보완재 설치'; }
                else { cause='환경 노이즈/정전기 → 조치 완료'; actionType='환경지도(노이즈)'; }
            }

            /* fallback */
            else {
                if(txt.includes('펌웨어')||txt.includes('업그레이드')) { cause='펌웨어/프로그램 업그레이드'; actionType='펌웨어 업그레이드'; }
                else if(txt.includes('재현안됨')||txt.includes('문제없음')||txt.includes('정상')) { cause='현장 방문 시 현상 재현 안됨'; actionType='단순 점검'; }
                else { cause='현장 점검 완료'; actionType='단순 점검'; }
            }
            } /* end isEnvNoise else */
        }

        d.rootCause=cause; d.actionType=actionType;
        d.displayPart=(d.isHW||d.isInstall)?d.실제부품목록.join(', '):'없음';
        d.hwStatusRaw=d.isHW?'HW불량':(d.isInstall?'보완재':'단순안내');
        /* 통신 종류 태그 (cat3 전용) */
        if(d.메타카테고리==='cat3'){
            const subL=(d.소분류||'').toLowerCase(); const ft=d.풀텍스트||'';
            const isBT=subL.includes('블루투스')||subL.includes('bluetooth')||ft.includes('블루투스')||ft.includes('bluetooth');
            const isWifi=subL.includes('wifi')||subL.includes('wi-fi')||subL.includes('와이파이')||ft.includes('wifi')||ft.includes('와이파이');
            const isLAN=subL.includes('lan')||subL.includes('lbweb')||ft.includes(' lan ')||ft.includes('랜선');
            if(isBT&&isWifi) d.commType='BT+WiFi';
            else if(isBT) d.commType='BT';
            else if(isWifi) d.commType='WiFi';
            else if(isLAN) d.commType='LAN';
            else d.commType='기타';
        } else { d.commType=null; }
        return d;
    });

    renderMultiSelect('dropRStatus',[{val:'HW불량',txt:'🚨 자재교체'},{val:'단순안내',txt:'✅ 단순방문'},{val:'보완재',txt:'⚠️ 보완재'}],'r-status-cb','renderReasonTable');
    applyGlobalFilters();
}

function applyGlobalFilters(){
    const fY=getCheckedValues('g-year-cb'),fD=getCheckedValues('g-dno-cb'),fP=getCheckedValues('g-prod-cb'),fC=getCheckedValues('g-cat-cb');
    currentData=globalRawData.filter(d=>{
        if(fY.length&&!fY.includes(d.연도))return false;
        if(fD.length){let ok=false;if(fD.includes('DNO2')&&dno2List.some(x=>d.제품명.replace(/\s/g,'').includes(x.replace(/\s/g,''))))ok=true;if(fD.includes('DNO3')&&dno3List.some(x=>d.제품명.replace(/\s/g,'').includes(x.replace(/\s/g,''))))ok=true;if(!ok)return false;}
        if(fP.length&&!fP.includes(d.제품명))return false;
        if(fC.length&&!fC.includes(d.원본대분류))return false;
        return true;
    });
    updateDashboard();
}

function resetAll(){
    document.querySelectorAll('input[type="checkbox"]').forEach(cb=>cb.checked=false);
    document.querySelectorAll('.ms-list.ms-open').forEach(el=>{el.classList.remove('ms-open');if(el.previousElementSibling)el.previousElementSibling.classList.remove('ms-open');});
    // 모든 배지 초기화
    document.querySelectorAll('.ms-btn .sel-badge').forEach(b=>b.textContent='0');
    document.querySelectorAll('.ms-btn.has-selection').forEach(b=>b.classList.remove('has-selection'));
    /* 버튼 레이블 원상복귀 */
    Object.entries(_defaultBtnLabels).forEach(([cls, lbl]) => {
        const boxes = document.querySelectorAll('.'+cls);
        if(!boxes.length) return;
        const list = boxes[0].closest('.ms-list');
        if(!list) return;
        const btn = list.previousElementSibling;
        if(!btn) return;
        const labelEl = btn.querySelector('.btn-label');
        if(labelEl) labelEl.textContent = lbl;
    });
    state.symptom=null;state.equipment=null;state.drillSubs=new Map();
    trendState.subOverlay.clear();
    applyGlobalFilters();
}
function setSymptomFilter(cat){
    const allCats = ['cat1','cat2','cat3','cat4','cat5','cat6','cat7','cat8'];
    state.drillSubs = new Map(); // 카테고리 바뀌면 드릴 초기화
    trendState.subOverlay.clear(); // 세부분류 오버레이도 초기화

    if(state.symptom===cat){
        // 토글 해제
        state.symptom=null;
        allCats.forEach(c => {
            if(c==='cat3'){ document.getElementById('cat3-sub-panel').classList.add('hidden'); }
            else { const pp = document.getElementById('cat-sub-panel-'+c); if(pp) pp.classList.add('hidden'); }
        });
        // 오버레이에서도 해당 cat 해제
        trendState.selected.delete(cat);
        // cat탭이었으면 체크박스 UI 갱신
        if(trendState.tab === 'cat') renderTrendCheckboxes();
    } else {
        state.symptom=cat;
        allCats.forEach(c => {
            if(c==='cat3'){ document.getElementById('cat3-sub-panel').classList.add('hidden'); }
            else { const pp = document.getElementById('cat-sub-panel-'+c); if(pp) pp.classList.add('hidden'); }
        });
        if(cat==='cat3'){
            const p3 = document.getElementById('cat3-sub-panel');
            p3.classList.remove('hidden');
            
        } else {
            const pp = document.getElementById('cat-sub-panel-'+cat);
            if(pp){
                pp.classList.remove('hidden');
                
            }
        }
        // ── 오버레이 자동 연동: cat탭으로 전환 + 해당 cat만 단일 선택 ──
        if(trendState.tab !== 'cat') {
            switchTrendTab('cat');  // 탭 전환 (내부에서 selected.clear() 호출됨)
        } else {
            trendState.selected.clear(); // 이전 cat 오버레이 제거
        }
        trendState.selected.add(cat);
        renderTrendCheckboxes();
    }
    updateDashboard();
}
function setEquipmentFilter(eq){state.equipment=(state.equipment===eq)?null:eq;updateDashboard();}

/* ══ 드릴다운: 하위분류 카드 클릭 → 전체 대시보드 연동 ══ */
function drillIntoSub(type, key, label, color) {
    // 이미 선택된 항목 클릭 시 토글 해제, 아니면 단일 선택
    if(state.drillSubs.has(key)) {
        state.drillSubs = new Map();
    } else {
        state.drillSubs = new Map();
        state.drillSubs.set(key, { type, key, label, color });
    }
    highlightDrillCards();
    if(state.drillSubs.size > 0) {
        const trendEl = document.getElementById('chartTrend');
        
    }
    updateDashboard();
}

function highlightDrillCards() {
    // cat3 카드
    document.querySelectorAll('#cat3-sub-cards > div').forEach(card => {
        const info = card.dataset && trendState.subOverlay.get(card.dataset.drillKey);
        card.style.outline = info ? `3px solid ${info.color}` : 'none';
        card.style.transform = info ? 'scale(1.03)' : 'scale(1)';
    });
    // 일반 cat 카드들
    document.querySelectorAll('[id^="cat-sub-panel-"] .cat-sub-cards > div').forEach(card => {
        const info = card.dataset && trendState.subOverlay.get(card.dataset.drillKey);
        card.style.outline = info ? `3px solid ${info.color}` : 'none';
        card.style.transform = info ? 'scale(1.03)' : 'scale(1)';
    });
}

function renderDrillBreadcrumb() {
    const el = document.getElementById('drillBreadcrumb');
    if(!el) return;
    if(!state.symptom && trendState.selected.size === 0 && trendState.subOverlay.size === 0){ el.classList.add('hidden'); return; }
    el.classList.remove('hidden');
    const parts = [];
    if(state.symptom){
        const catName = {cat1:'측정결함',cat2:'체중/영점',cat3:'통신/네트워크',cat4:'디스플레이',cat5:'전원/외부기기',cat6:'고객문의',cat7:'장비동작이상',cat8:'노이즈'}[state.symptom]||state.symptom;
        parts.push(`<span class="drill-crumb" onclick="setSymptomFilter('${state.symptom}')" style="cursor:pointer;color:#2563eb;font-weight:800;">${catName}</span>`);
    }
    if(trendState.subOverlay.size > 0){
        parts.push(`<span style="color:#94a3b8;">›</span>`);
        trendState.subOverlay.forEach((info, key) => {
            parts.push(`<span style="cursor:pointer;color:${info.color};font-weight:800;background:${info.color}18;padding:1px 7px;border-radius:10px;margin-right:3px;" onclick="trendState.subOverlay.delete('${key}');renderTrendChart();updateDashboard();">${info.label} <span style="font-size:9px;opacity:0.6;">(세부)</span></span>`);
        });
    }
    if(trendState.selected.size > 0){
        const trendLabel = trendState.tab === 'cat' ? '불량구분' : '제품';
        const items = Array.from(trendState.selected).join(', ');
        parts.push(`<span style="color:#94a3b8;">›</span>`);
        parts.push(`<span style="cursor:pointer;color:#7c3aed;font-weight:800;" onclick="clearTrendOverlay()">📈 ${trendLabel}: ${items}</span>`);
    }
    parts.push(`<span style="color:#64748b;font-size:11px;"> — ${filteredData.length}건</span>`);
    parts.push(`<button onclick="clearDrill()" style="margin-left:8px;font-size:10px;color:#ef4444;font-weight:800;background:#fef2f2;border:1px solid #fca5a5;border-radius:6px;padding:1px 7px;cursor:pointer;">✕ 초기화</button>`);
    el.innerHTML = '🔍 ' + parts.join(' ');
}

function clearDrill() {
    state.drillSubs = new Map();
    state.symptom = null;
    trendState.selected.clear();
    trendState.subOverlay.clear();
    ['cat1','cat2','cat3','cat4','cat5','cat6','cat7','cat8'].forEach(c=>{
        if(c==='cat3'){ document.getElementById('cat3-sub-panel').classList.add('hidden'); }
        else { const pp=document.getElementById('cat-sub-panel-'+c); if(pp) pp.classList.add('hidden'); }
    });
    updateDashboard();
}


