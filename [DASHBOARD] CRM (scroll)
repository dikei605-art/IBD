function openSubCatActionDrill(actionType, subCat) {
    const drillArea = document.getElementById('subcatDrillArea');
    if (!drillArea) return;

    // 같은 항목 재클릭 시 닫기
    if (!drillArea.classList.contains('hidden') && drillArea.dataset.action === actionType) {
        drillArea.classList.add('hidden');
        return;
    }
    drillArea.dataset.action = actionType;

    const baseData = (window._subcatBaseData || []).filter(d => d.actionType === actionType);
    const total = baseData.length;
    if (!total) return;

    // 키워드 패턴 매칭
    const rules = actionPatternRules[actionType] || [];
    const patCounts = {};
    const unclass = [];
    rules.forEach(r => patCounts[r.label] = 0);
    baseData.forEach(doc => {
        const txt = doc.풀텍스트 || '';
        let matched = false;
        for (const rule of rules) {
            if (rule.keywords.some(kw => txt.includes(kw))) {
                patCounts[rule.label]++;
                matched = true;
                break;
            }
        }
        if (!matched) unclass.push(doc.풀텍스트);
    });
    if (unclass.length) patCounts['기타(미분류)'] = unclass.length;

    const sorted = Object.entries(patCounts).filter(([,v])=>v>0).sort((a,b)=>b[1]-a[1]);
    const barColors = ['#2563eb','#3b82f6','#60a5fa','#93c5fd','#bfdbfe'];

    drillArea.classList.remove('hidden');
    drillArea.innerHTML = `
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-3 drill-anim">
            <div class="flex items-center justify-between mb-2">
                <p class="text-[11px] font-black text-blue-800">🔍 ${actionType} — ${total}건 세부</p>
                <button onclick="document.getElementById('subcatDrillArea').classList.add('hidden')"
                        class="text-blue-400 hover:text-blue-700 text-base leading-none">✕</button>
            </div>
            <div class="space-y-1.5">
            ${sorted.map(([label,count],i) => {
                const pct = Math.round(count/total*100);
                const isEtc = label.includes('기타')||label.includes('미분류');
                return `<div>
                    <div class="flex justify-between text-[10px] mb-0.5">
                        <span class="font-medium text-blue-700 flex-1 break-words">${label}</span>
                        <span class="font-black text-blue-800 shrink-0 ml-1">${count}건 (${pct}%)</span>
                    </div>
                    <div class="w-full bg-blue-100 rounded-full h-2">
                        <div class="h-2 rounded-full transition-all duration-700"
                             style="width:${pct}%;background:${isEtc?'#f59e0b':barColors[Math.min(i,barColors.length-1)]}"></div>
                    </div>
                </div>`;
            }).join('')}
            </div>
        </div>`;
}

