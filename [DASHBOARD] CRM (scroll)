function renderSubCatWithCount(containerId, data) {
    const c = document.getElementById(containerId); if (!c) return;
    // 소분류별 건수 집계
    const countMap = {};
    data.forEach(d => {
        const sc = d.소분류 || '미분류';
        countMap[sc] = (countMap[sc] || 0) + 1;
    });
    const sorted = Object.entries(countMap).sort((a,b) => a[0].localeCompare(b[0]));

    c.innerHTML = '';
    // 전체선택 (기존 all-lbl 스타일 유지)
    const al = document.createElement('label');
    al.className = 'all-lbl';
    al.innerHTML = `<input type="checkbox" class="sel-all-r-subcat-cb" onchange="toggleAll(this,'r-subcat-cb','renderReasonTable')"> ☑️ 전체 선택 / 해제`;
    c.appendChild(al);

    sorted.forEach(([val, cnt]) => {
        const l = document.createElement('label');
        l.className = 'subcat-clickable';
        l.dataset.subcat = val;
        l.innerHTML = `
            <input type="checkbox" value="${val}" class="r-subcat-cb"
                onchange="checkIndividual(this,'sel-all-r-subcat-cb','renderReasonTable')">
            <span style="flex:1;overflow:hidden;text-overflow:ellipsis;">${val}</span>
            <span class="ms-count-badge">${cnt}건</span>`;
        // 클릭 시 패널 요약 (체크박스 클릭 제외)
        l.addEventListener('click', function(e) {
            if (e.target.type === 'checkbox') return;
            e.preventDefault();
            // 체크박스도 토글
            const cb = l.querySelector('input[type="checkbox"]');
            cb.checked = !cb.checked;
            checkIndividual(cb, 'sel-all-r-subcat-cb', 'renderReasonTable');
            openSubCatSummary(val);
        });
        c.appendChild(l);
    });
}

function openSubCatSummary(subCat) {
    // 같은 항목 재클릭 시 닫기
    if (currentSubCat === subCat) {
        currentSubCat = null;
        // 소분류 강조 해제
        document.querySelectorAll('#dropRSubCat label.subcat-clickable').forEach(l => l.classList.remove('subcat-active'));
        closePanelDetail();
        return;
    }
    currentSubCat = subCat;
    currentPanelActionType = null;  // 조치유형 패널 모드 해제

    // 소분류 라벨 강조
    document.querySelectorAll('#dropRSubCat label.subcat-clickable').forEach(l => {
        l.classList.toggle('subcat-active', l.dataset.subcat === subCat);
    });
    // 조치유형 버튼 강조 해제
    document.querySelectorAll('.action-type-btn').forEach(b => b.classList.remove('ring-2','ring-blue-400','bg-blue-600','text-white'));

    // 패널 헤더 변경
    document.getElementById('panelHeaderTitle').textContent = '📊 소분류 요약 분석';
    document.getElementById('panelModeBadge').textContent = '소분류';
    document.getElementById('panelModeBadge').classList.remove('hidden');
    document.getElementById('panelCloseBtn').classList.remove('hidden');

    // 해당 소분류 데이터 추출 (테이블 필터 적용)
    const fS=getCheckedValues('r-status-cb'),fE=getCheckedValues('r-equip-cb'),fC=getCheckedValues('r-cause-cb'),fT=getCheckedValues('r-type-cb'),fP=getCheckedValues('r-part-cb');
    let baseData = filteredData.filter(d => (d.소분류||'미분류') === subCat);
    if(fS.length) baseData = baseData.filter(d => { const s=d.isHW?'HW불량':(d.isInstall?'보완재':'단순안내'); return fS.includes(s); });
    if(fE.length) baseData = baseData.filter(d => fE.includes(d.제품명));
    if(fC.length) baseData = baseData.filter(d => fC.includes(d.rootCause));
    if(fT.length) baseData = baseData.filter(d => fT.includes(d.actionType));
    if(fP.length) baseData = baseData.filter(d => fP.includes(d.displayPart));

    const total = baseData.length;
    if (!total) {
        document.getElementById('panelContent').innerHTML = `<div class="flex items-center justify-center h-full text-gray-400 text-sm font-bold">해당 소분류 데이터가 없습니다</div>`;
        return;
    }

    // 조치유형 집계
    const actionMap = {};
    baseData.forEach(d => { actionMap[d.actionType] = (actionMap[d.actionType]||0) + 1; });
    const actionSorted = Object.entries(actionMap).sort((a,b)=>b[1]-a[1]);

