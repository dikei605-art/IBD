function getPeriodKey(d) {
    if(trendState.period === 'yearly')  return d.연도 || '미상';
    if(trendState.period === 'monthly') return d.월별 || '미상';
    if(trendState.period === 'weekly') {
        // 접수일에서 주차 계산
        const raw = d._접수일raw;
        if(!raw || raw === '미상') return '미상';
        let dt;
        if(typeof raw === 'number') dt = new Date((raw - 25569) * 86400 * 1000);
        else dt = new Date(String(raw).replace(/\./g,'-'));
        if(isNaN(dt)) return '미상';
        // ISO 주차
        const jan1 = new Date(dt.getFullYear(), 0, 1);
        const week = Math.ceil(((dt - jan1) / 86400000 + jan1.getDay() + 1) / 7);
        return `${dt.getFullYear()}-W${String(week).padStart(2,'0')}`;
    }
    return d.월별 || '미상';
}

