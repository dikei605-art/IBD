    const btns = document.querySelectorAll('.trend-period-btn');
    if(btns[idx]) {
        btns[idx].classList.add('bg-white','text-blue-700','shadow');
        btns[idx].classList.remove('text-gray-500');
    }
    const titles = {monthly:'월별 발생 추이', weekly:'주별 발생 추이', yearly:'연별 발생 추이'};
    document.getElementById('titleTrend').textContent = '📈 ' + titles[period];
    renderTrendChart();
}

function switchTrendTab(tab) {
    trendState.tab = tab;
    trendState.selected.clear();
    trendState.subOverlay.clear();
    ['product','cat','stacked'].forEach(t => {
        const btn = document.getElementById('trend-tab-' + t);
        if(!btn) return;
        if(t === tab) { btn.classList.add('bg-white','text-blue-700','shadow'); btn.classList.remove('text-gray-500'); }
        else { btn.classList.remove('bg-white','text-blue-700','shadow'); btn.classList.add('text-gray-500'); }
    });
    // 누적막대는 오버레이 체크박스 숨김
    const ctrl = document.getElementById('trend-overlay-controls');
    if(ctrl) ctrl.style.display = tab === 'stacked' ? 'none' : 'flex';
    renderTrendCheckboxes();
    renderTrendChart();
}

function renderTrendCheckboxes() {
    const container = document.getElementById('trend-checkboxes');
    if(!container || trendState.tab === 'stacked') return;
    let items = [];
    if(trendState.tab === 'product') {
        const equips = {};
        currentData.forEach(d => { if(d.제품명) equips[d.제품명] = (equips[d.제품명]||0)+1; });
        items = Object.entries(equips).sort((a,b)=>b[1]-a[1]).slice(0,15).map(([k])=>k);
        /* 순서 기반으로 색상 재배정 (캐시 리셋 후 목록 순서대로) */
        resetProductColors();
        items.forEach(item => getProductColor(item));
    } else {
        items = ['cat1','cat2','cat3','cat4','cat5','cat6','cat7','cat8'];
    }
    container.innerHTML = items.map((item, i) => {
        const label = trendState.tab === 'cat' ? catLabels[item] : item;
        const color = trendState.tab === 'cat' ? catColors[item] : getProductColor(item);
        const checked = trendState.selected.has(item);
        return `<label style="display:flex;align-items:center;gap:4px;cursor:pointer;font-size:11px;font-weight:700;
                    padding:3px 8px;border-radius:12px;border:1.5px solid ${checked ? color : '#e2e8f0'};
                    background:${checked ? color+'18' : '#f8fafc'};color:${checked ? color : '#64748b'};"
                    onclick="toggleTrendItem('${item}',this,'${color}',event)">
                <span style="width:8px;height:8px;border-radius:50%;background:${color};flex-shrink:0;display:inline-block;"></span>
                ${label}
            </label>`;
    }).join('');
}

function toggleTrendItem(item, labelEl, color, e) {
    if(e) e.preventDefault();
    if(trendState.selected.has(item)) {
        trendState.selected.delete(item);
        labelEl.style.borderColor = '#e2e8f0';
        labelEl.style.background = '#f8fafc';
        labelEl.style.color = '#64748b';
        // cat탭이면 cat 카드도 해제
        if(trendState.tab === 'cat' && state.symptom === item) {
            state.symptom = null;
            state.drillSubs = new Map();
            ['cat1','cat2','cat3','cat4','cat5','cat6','cat7','cat8'].forEach(c => {
                if(c==='cat3'){ document.getElementById('cat3-sub-panel').classList.add('hidden'); }
                else { const pp = document.getElementById('cat-sub-panel-'+c); if(pp) pp.classList.add('hidden'); }
            });
        }
    } else {
        trendState.selected.add(item);
        labelEl.style.borderColor = color;
        labelEl.style.background = color + '18';
        labelEl.style.color = color;
        // cat탭이면 cat 카드도 자동 선택 (단일 교체)
        if(trendState.tab === 'cat') {
            const allCats = ['cat1','cat2','cat3','cat4','cat5','cat6','cat7','cat8'];
            state.drillSubs = new Map();
            trendState.subOverlay.clear(); // 이전 세부분류 오버레이 초기화
            // 오버레이도 단일 선택 (이전 cat 제거 후 새것만)
            trendState.selected.clear();
            trendState.selected.add(item);
            state.symptom = item;
            allCats.forEach(c => {
                if(c==='cat3'){ document.getElementById('cat3-sub-panel').classList.add('hidden'); }
                else { const pp = document.getElementById('cat-sub-panel-'+c); if(pp) pp.classList.add('hidden'); }
            });
            if(item === 'cat3'){
                const p3 = document.getElementById('cat3-sub-panel');
                if(p3) { p3.classList.remove('hidden'); }
            } else {
                const pp = document.getElementById('cat-sub-panel-'+item);
                if(pp){ pp.classList.remove('hidden'); }
            }
            renderTrendCheckboxes();
        }
    }
    updateDashboard();
}

function toggleTrendTotal(el) {
