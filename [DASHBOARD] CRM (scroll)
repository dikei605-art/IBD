        if(!reasonMap[key])reasonMap[key]={status,equip:d.제품명,subCat:d.소분류||'미분류',cause:d.rootCause,type:d.actionType,part:d.displayPart,commType:d.commType||null,count:0};
        reasonMap[key].count++;uEq2.add(d.제품명);uSubCat2.add(d.소분류||'미분류');uCa.add(d.rootCause);uTy.add(d.actionType);uPa.add(d.displayPart);
