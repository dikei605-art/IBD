}

function renderTrendChart() {
    /* 1. 전체 기간 라벨 수집
       - 오버레이 선택 시: currentData 기준 (전체 막대 유지하여 비교 가능)
       - 오버레이 없을 시: filteredData 기준 (cat/연도 필터 반영) */
    const trendBase = trendState.selected.size > 0 ? currentData : filteredData;
    const allTrends = {};
    trendBase.forEach(d => {
        const key = getPeriodKey(d);
        if(key !== '미상') allTrends[key] = (allTrends[key]||0) + 1;
    });
    const labels = Object.keys(allTrends).sort();
    if(!labels.length) return;

    let datasets = [];

    /* ── 누적막대 모드 ── */
    if(trendState.tab === 'stacked') {
        const equips = {};
        filteredData.forEach(d => { if(d.제품명) equips[d.제품명] = (equips[d.제품명]||0)+1; });
        const topProducts = Object.entries(equips).sort((a,b)=>b[1]-a[1]).slice(0,12).map(([k])=>k);

        datasets = topProducts.map((prod, i) => {
            const prodTrends = {};
            filteredData.forEach(d => {
                if(d.제품명 !== prod) return;
                const key = getPeriodKey(d);
                if(key !== '미상') prodTrends[key] = (prodTrends[key]||0)+1;
            });
            return {
                label: prod,
                type: 'bar',
                data: labels.map(l => prodTrends[l] || 0),
                backgroundColor: stackedColors[i % stackedColors.length] + 'cc',
                borderColor: stackedColors[i % stackedColors.length],
                borderWidth: 0,
                stack: 'products',
                datalabels: { display: false },
            };
        });

        // 전체 합계 라인
        datasets.push({
            label: '전체',
            type: 'line',
            data: labels.map(l => allTrends[l]),
            borderColor: '#1e293b',
            backgroundColor: 'transparent',
            borderWidth: 2,
            borderDash: [4,3],
            pointRadius: 3,
            tension: 0.3,
            fill: false,
            stack: undefined,
            datalabels: {
                display: true,
                anchor: 'end',
                align: 'top',
                color: '#334155',
                font: { size: 9, weight: 'bold' },
                formatter: v => v,
            },
        });
    } else {
        /* ── 일반 모드: 회색 bar + 추이선 + 오버레이 ── */
        datasets = [];
        if(trendState.showTotal) {
            datasets.push({
                label: '전체 발생건수',
                type: 'bar',
                data: labels.map(l => allTrends[l]),
                backgroundColor: 'rgba(148,163,184,0.3)',
                borderColor: 'rgba(148,163,184,0.5)',
                borderWidth: 1,
                order: 10,
                datalabels: {
                    display: true,
                    anchor: 'end',
                    align: 'top',
                    offset: 1,
                    color: '#475569',
                    font: { size: 10, weight: 'bold' },
                    formatter: v => v > 0 ? v : '',
                    clamp: true,
                },
            }, {
                label: '전체 추이',
                type: 'line',
                data: labels.map(l => allTrends[l]),
                borderColor: 'rgba(100,116,139,0.8)',
                borderWidth: 2,
                borderDash: [5,3],
                pointRadius: 4,
                pointBackgroundColor: 'rgba(100,116,139,0.8)',
                tension: 0.3,
                fill: false,
                order: 2,
                datalabels: { display: false },
            });
        }

        /* 선택 오버레이 라인 */
        trendState.selected.forEach(item => {
            const color = trendState.tab === 'cat'
                ? catColors[item]
                : getProductColor(item);
            const label = trendState.tab === 'cat' ? catLabels[item] : item;
            const itemTrends = {};
            filteredData.forEach(d => {
                const key = getPeriodKey(d);
                if(key === '미상') return;
                const hit = trendState.tab === 'cat' ? d.메타카테고리 === item : d.제품명 === item;
                if(hit) itemTrends[key] = (itemTrends[key]||0)+1;
            });
            datasets.push({
                label,
                type: 'line',
                data: labels.map(l => itemTrends[l] || 0),
                borderColor: color,
                backgroundColor: color + '20',
                borderWidth: 2.5,
                pointRadius: 3,
                pointHoverRadius: 5,
                tension: 0.3,
                fill: false,
                order: 1,
                datalabels: {
                    display: true,
                    anchor: 'end',
                    align: 'top',
                    offset: 4,
                    color: color,
                    font: { size: 9, weight: 'bold' },
                    formatter: v => v > 0 ? v : '',
                    clamp: true,
                    backgroundColor: 'rgba(255,255,255,0.75)',
                    borderRadius: 3,
                    padding: { top: 1, bottom: 1, left: 2, right: 2 },
                },
            });
        });

        /* 세부분류 오버레이 라인 (subOverlay) */
        trendState.subOverlay.forEach((info, key) => {
            const subTrends = {};
            filteredData.forEach(d => {
                const periodKey = getPeriodKey(d);
                if(periodKey === '미상') return;
                if(info.filterFn(d)) subTrends[periodKey] = (subTrends[periodKey]||0)+1;
            });
            datasets.push({
                label: info.label,
                type: 'line',
                data: labels.map(l => subTrends[l] || 0),
                borderColor: info.color,
                backgroundColor: info.color + '20',
                borderWidth: 2,
                borderDash: [3, 2],
                pointRadius: 3,
                pointHoverRadius: 5,
                tension: 0.3,
                fill: false,
                order: 1,
                datalabels: {
                    display: true,
                    anchor: 'end',
                    align: 'bottom',
                    offset: 4,
                    color: info.color,
                    font: { size: 9, weight: 'bold' },
