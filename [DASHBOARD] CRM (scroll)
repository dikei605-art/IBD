                    backgroundColor: 'rgba(255,255,255,0.75)',
                    borderRadius: 3,
                    padding: { top: 1, bottom: 1, left: 2, right: 2 },
                },
            });
        });
    }

    destroyChart('Trend');
    charts['Trend'] = new Chart(document.getElementById('chartTrend'), {
        data: { labels, datasets },
        options: {
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { display: trendState.tab === 'stacked', position: 'bottom',
                    labels: { font: { size: 10 }, boxWidth: 12, padding: 8 } },
                datalabels: {
                    display: ctx => {
                        const ds = ctx.dataset;
                        if(trendState.tab === 'stacked') return ds.type === 'line';
                        if(ds.type === 'bar') return true;
                        // 오버레이 라인은 개별 datalabels로 처리
                        return false;
                    },
                    anchor: 'end', align: 'top', offset: 1,
                    color: '#334155', font: { size: 10, weight: 'bold' },
                    formatter: v => v > 0 ? v : '', clamp: true,
                },
                tooltip: { callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y}건` } }
            },
            scales: {
                x: { grid: { display: false }, ticks: { font: { size: 10 }, maxRotation: 45 },
                     stacked: trendState.tab === 'stacked' },
                y: { beginAtZero: true, ticks: { font: { size: 11 } },
                     grace: '15%', stacked: trendState.tab === 'stacked' }
            }
        }
    });

    /* 범례 (누적막대 아닐 때) */
    const legend = document.getElementById('trend-legend');
    if(legend && trendState.tab !== 'stacked') {
        const items = [
            `<span style="display:flex;align-items:center;gap:4px;font-size:10px;color:#94a3b8;font-weight:700;">
                <span style="width:14px;height:10px;background:rgba(148,163,184,0.4);display:inline-block;border-radius:2px;"></span>전체
            </span>`
        ];
        trendState.selected.forEach(item => {
            const color = trendState.tab==='cat' ? catColors[item] : getProductColor(item);
            const lbl = trendState.tab==='cat' ? catLabels[item] : item;
            items.push(`<span style="display:flex;align-items:center;gap:4px;font-size:10px;color:${color};font-weight:700;">
                <span style="width:20px;height:2.5px;background:${color};display:inline-block;border-radius:2px;"></span>${lbl}
            </span>`);
        });
        trendState.subOverlay.forEach((info, key) => {
            items.push(`<span style="display:flex;align-items:center;gap:4px;font-size:10px;color:${info.color};font-weight:700;">
                <span style="width:20px;height:2.5px;background:${info.color};display:inline-block;border-radius:2px;border-top:1px dashed ${info.color};"></span>${info.label} <span style="font-size:9px;opacity:0.7;">(세부)</span>
            </span>`);
        });
        legend.innerHTML = items.join('');
    } else if(legend && trendState.tab === 'stacked') {
        legend.innerHTML = '';
    }

    if(!document.getElementById('trend-checkboxes').children.length) renderTrendCheckboxes();
}


