        if(di.year!=='미상')uYr.add(di.year);
        const subCat=subCatRaw; // 위에서 이미 읽음
        if(!docsMap[docNo]){
            const content=(getColValue(row,['접수내용'])+' '+getColValue(row,['처리내용'])).toLowerCase();
            /* ── 메타카테고리: 소분류 직접 매핑 → 대분류 fallback → 노이즈 감지 ── */
            let metaCat = subCatToCat[subCat] || null;
