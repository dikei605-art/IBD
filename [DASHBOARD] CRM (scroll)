/* 품목명 → 매핑 결과 반환 */
function classifyPart(partName) {
    const p = partName.trim();
    for (const rule of partsMasterRules) {
        if (rule.re.test(p)) {
            return {
                label: rule.label,
                cause: rule.cause || `${rule.label} 불량 (${p})`,
                cat:   rule.cat
            };
        }
    }
    return { label:'기타', cause:`기타 부품 불량 (${p})`, cat:null };
}

/* 문서의 실제부품목록 전체를 분류 → 대표 결과 반환
   우선순위: 로드셀 > 통신모듈 > LCD > Board계열 > 케이블 > 기타 */
const partPriority = [
    '로드셀 / 체중센서','통신모듈 (WiFi/BT)','LCD / 터치스크린',
    '메인보드 (DNO)','측정 보드 (Analog/ANO)','로드셀 보드',
    '사지 측정 보드','인터페이스 보드 (IF/INO)','키패드 보드',
    '화면 보드 (LNO)','손 전극 보드','발 전극 보드','기타 보드',
    '기타 기판 (PCB)',
    '손 전극케이블','발 전극케이블','전원/스위치 케이블',
    '전원 어댑터','스피커','스위치 / 버튼','배터리',
    '헤드바 (신장계)','프린터 모듈','기타 케이블','전극 부품','기타 부품',
];

function classifyPartsAll(partsList) {
    if (!partsList || !partsList.length) return null;
    const results = partsList.map(p => classifyPart(p));
    // 우선순위 가장 높은 결과 반환
    let best = results[0];
    for (const r of results) {
        if (partPriority.indexOf(r.label) < partPriority.indexOf(best.label)) best = r;
    }
    return best;
}

