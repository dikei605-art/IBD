        ${emptyCount > 0 ? `
        <div class="mt-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2">
            <p class="text-[10px] font-black text-red-700">💡 개선 제안</p>
            <p class="text-[10px] text-red-600 mt-0.5">샘플 중 <strong>${emptyCount}건</strong>이 내용 미입력 상태입니다.<br>처리내용 입력 기준을 수립하면 분류 정확도가 높아집니다.</p>
        </div>` : ''}`;
}
</script>
</body>
</html>
