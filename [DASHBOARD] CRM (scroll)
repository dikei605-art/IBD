function classifyCatSub(d, catKey) {
    const rules = catSubRules[catKey];
    if(!rules) return 'etc';
    const sub   = (d.소분류 || '').toLowerCase();
    const txt   = (d.풀텍스트 || '').toLowerCase();
    const parts = d.실제부품목록.map(p => p.toLowerCase()).join(' ');
    for(const [key, rule] of Object.entries(rules.items)){
        if(key === 'etc') continue;
        const subHit  = rule.subMatch.some(s => sub.includes(s.toLowerCase()));
        const textHit = (rule.textMatch||[]).some(s => txt.includes(s.toLowerCase()));
        const partHit = rule.partMatch.length > 0 && rule.partMatch.some(p => new RegExp(p,'i').test(parts));
        if(subHit || textHit || partHit) return key;
    }
    return 'etc';
}

