    { status: '단순안내', label: '✅ 단순안내/설정',   barColor: '#10b981', barBg: '#d1fae5', tagBg: '#d1fae5', tagColor: '#065f46' },
];

function renderTabView(data) {
    if (!data) data = window._currentDisplayData || filteredData;
    const nav    = document.getElementById('rnTabNav');
    const panels = document.getElementById('rnTabPanels');
    if (!nav || !panels) return;

    // 현재 활성 탭 기억 (재렌더 후 복원)
    const activeBtn = nav.querySelector('.rn-tab-btn.active');
    const activeStatus = activeBtn ? activeBtn.dataset.status : null;

    // ── 상세원인 기준 집계 (장비 중복 통합, 불량카테고리 + 동반교체 포함) ──
    const causeMap = {};
    data.forEach(d => {
        const status = d.isHW ? 'HW불량' : (d.isInstall ? '보완재' : '단순안내');
        const key = status + '||' + d.rootCause + '||' + d.actionType;
        if (!causeMap[key]) {
            causeMap[key] = {
                status, cause: d.rootCause, actionType: d.actionType,
                metaCat: d.메타카테고리 || '미분류_기타',
                repLabel: (classifyPartsAll(d.실제부품목록) || {}).label || null,
                count: 0,
                soloCount: 0,      // 대표 부품만 단독 교체
                comboCount: 0,     // 다른 카테고리 부품 동반 교체
                partCounts: {},    // 대표 카테고리 자재명
                companionCats: {}  // 동반 교체 카테고리 집계
            };
        }
        causeMap[key].count++;

        if (d.isHW || d.isInstall) {
            const repLabel = causeMap[key].repLabel;
            let hasCompanion = false;

            d.실제부품목록.forEach(p => {
                if (!p) return;
                const pLabel = classifyPart(p).label;
                if (pLabel === repLabel) {
                    // 대표 카테고리 → 자재명 집계
                    causeMap[key].partCounts[p] = (causeMap[key].partCounts[p] || 0) + 1;
                } else {
                    // 다른 카테고리 → 동반 교체 집계
                    hasCompanion = true;
                    causeMap[key].companionCats[pLabel] = (causeMap[key].companionCats[pLabel] || 0) + 1;
                }
            });

            if (hasCompanion) causeMap[key].comboCount++;
            else causeMap[key].soloCount++;
        }
    });

    const allItems = Object.values(causeMap).sort((a, b) => b.count - a.count);

    // ── 탭별 건수 계산 ──
    const statusTotals = {};
    allItems.forEach(it => { statusTotals[it.status] = (statusTotals[it.status] || 0) + it.count; });

    // ── 탭 네비 생성 ──
    const activeTabs = tabConfig.filter(t => statusTotals[t.status] > 0);
    if (!activeTabs.length) {
        nav.innerHTML = '';
        panels.innerHTML = '<div class="tab-empty">📭 데이터가 없습니다</div>';
        return;
    }

    // 이전 탭이 현재 activeTabs에 있으면 유지, 없으면 첫 번째
    const restoreStatus = activeStatus && activeTabs.some(t => t.status === activeStatus)
        ? activeStatus : activeTabs[0].status;

    nav.innerHTML = activeTabs.map((t) => {
        const cnt = statusTotals[t.status] || 0;
        const isActive = t.status === restoreStatus;
        return `<button class="rn-tab-btn ${isActive ? 'active' : ''}"
                    data-status="${t.status}"
                    onclick="rnSwitchTab(this, 'rn-panel-${t.status}')">
            ${t.label}
            <span class="rn-tab-count" style="background:${t.barBg};color:${t.tagColor};">${cnt}건</span>
        </button>`;
    }).join('');

    // ── 패널 생성 ──
    panels.innerHTML = activeTabs.map((t, i) => {
        const items = allItems.filter(it => it.status === t.status);
        const total = statusTotals[t.status] || 1;

        const rows = items.map(item => {
            const pct = Math.round(item.count / total * 100);

            // 불량카테고리 뱃지
            const cm = catMeta[item.metaCat] || catMeta['미분류_기타'];
            const catBadge = `<span style="display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;background:${cm.bg};color:${cm.color};white-space:nowrap;">${cm.label}</span>`;

            // 주 자재명 Top5
            const topParts = Object.entries(item.partCounts)
                .sort((a, b) => b[1] - a[1]).slice(0, 5);
            const partsHTML = topParts.length > 0
                ? topParts.map(([name, cnt]) =>
                    `<span class="part-tag-sm">${name}<span class="pt-cnt"> ${cnt}건</span></span>`
                  ).join('')
                : `<span style="font-size:11px;color:#cbd5e1;font-style:italic;">없음</span>`;

            // 동반 교체 현황
            let companionHTML = '';
            if (item.comboCount > 0) {
                const soloRatio = Math.round(item.soloCount / (item.soloCount + item.comboCount) * 100);
                const comboRatio = 100 - soloRatio;
                // 동반 카테고리 상위 2개
                const topCompanions = Object.entries(item.companionCats)
                    .sort((a, b) => b[1] - a[1]).slice(0, 2)
                    .map(([label]) => label.replace(/[📏⚖️📶🖥️⚡👤⚙️🌩️❓]/gu, '').trim())
                    .join(', ');
                companionHTML = `
                    <div style="margin-top:5px;font-size:10px;">
                        <div style="display:flex;gap:3px;align-items:center;margin-bottom:3px;">
                            <div style="height:6px;border-radius:3px;background:#e2e8f0;flex:1;overflow:hidden;">
                                <div style="height:100%;width:${soloRatio}%;background:#10b981;border-radius:3px;display:inline-block;"></div>
                                <div style="height:100%;width:${comboRatio}%;background:#f97316;border-radius:3px;display:inline-block;"></div>
                            </div>
                        </div>
                        <span style="color:#10b981;font-weight:800;">단독 ${item.soloCount}건</span>
                        <span style="color:#94a3b8;margin:0 3px;">|</span>
                        <span style="color:#f97316;font-weight:800;">+동반 ${item.comboCount}건</span>
                        ${topCompanions ? `<div style="color:#94a3b8;margin-top:2px;font-size:9px;">함께 교체: ${topCompanions}</div>` : ''}
                    </div>`;
            } else if (item.soloCount > 0) {
                companionHTML = `<div style="margin-top:5px;font-size:10px;color:#10b981;font-weight:800;">단독 교체 ${item.soloCount}건</div>`;
            }

            // 조치유형 버튼
            const typeBtn = `<button class="action-type-btn"
                onclick="openActionDetail('${item.actionType.replace(/'/g,"\\'")}', ${item.count})"
                title="클릭하여 세부 분석">
                ${item.actionType} <span style="font-size:9px;opacity:.7;">🔍</span>
            </button>`;

            return `<tr>
                <td style="white-space:nowrap;">${catBadge}</td>
                <td>
                    <div class="agg-cause-main">${item.cause}</div>
                    ${companionHTML}
                </td>
                <td>${partsHTML}</td>
                <td style="white-space:nowrap;">${typeBtn}</td>
                <td style="min-width:90px;">
                    <span class="agg-count-num" style="color:${t.barColor};">${item.count}</span>
                    <div class="agg-share-bar-wrap">
                        <div class="agg-share-bar-fill" style="width:${pct}%;background:${t.barColor};"></div>
                    </div>
                    <div class="agg-share-pct">${pct}%</div>
                </td>
            </tr>`;
        }).join('');

        return `<div class="rn-tab-panel ${t.status === restoreStatus ? 'active' : ''}" id="rn-panel-${t.status}">
            <table class="agg-tbl">
                <thead>
                    <tr>
                        <th style="width:16%;">불량 카테고리</th>
                        <th style="width:26%;">상세 원인</th>
                        <th style="width:29%;">자재명 Top5 (건수)</th>
                        <th style="width:14%;">조치유형</th>
                        <th style="width:15%;">건수/비중</th>
                    </tr>
                </thead>
                <tbody>${rows || '<tr><td colspan="5" class="tab-empty">해당 데이터 없음</td></tr>'}</tbody>
            </table>
        </div>`;
    }).join('');
}

function rnSwitchTab(btn, panelId) {
    document.querySelectorAll('.rn-tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.rn-tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    const panel = document.getElementById(panelId);
    if (panel) panel.classList.add('active');
}

