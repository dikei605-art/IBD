                if(noiseActionPat.test(content)){metaCat='cat8';}
                else{for(const[key,list]of Object.entries(categoryMap)){if(list.includes(mainCat)){metaCat=key;break;}}}
            }
            metaCat = metaCat || '미분류_기타';
            docsMap[docNo]={문서번호:docNo,제품명:equip,월별:di.month,연도:di.year,
