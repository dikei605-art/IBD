            <div class="flex items-start justify-between gap-2">
                <p class="text-[12px] font-black text-gray-800 leading-snug break-words flex-1">${subCat}</p>
                <span class="text-xl font-black text-blue-700 shrink-0">${total}건</span>
            </div>

            <!-- 조치유형 분포 -->
            <div>
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-wide mb-2">조치유형 분포 <span class="text-gray-300 font-normal">(클릭 → 상세)</span></p>
                <div class="space-y-1.5" id="subcatActionBars">
                ${actionSorted.map(([label,count],i) => {
                    const pct = Math.round(count/total*100);
                    const col = barColors[Math.min(i, barColors.length-1)];
                    return `<div class="cursor-pointer hover:bg-blue-50 rounded-lg p-1 -mx-1 transition group"
                                 onclick="openSubCatActionDrill('${label.replace(/'/g,"\\'")}', '${subCat.replace(/'/g,"\\'")}')">
                        <div class="flex justify-between items-center mb-0.5">
                            <span class="text-[11px] font-bold text-gray-700 group-hover:text-blue-700 flex-1 break-words">${label}</span>
                            <span class="text-[11px] font-black text-blue-700 shrink-0 ml-1">${count}건 <span class="text-[9px] text-blue-400">▶</span></span>
