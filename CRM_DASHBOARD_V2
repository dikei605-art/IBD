            <!-- 드릴다운 영역 -->
            <div id="subcatDrillArea" class="hidden"></div>

            <!-- 상세원인 Top -->
            <div>
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-wide mb-1.5">상세원인 Top ${causeSorted.length}</p>
                <div class="space-y-1">
                ${causeSorted.map(([cause,cnt]) => `
                    <div class="flex justify-between items-center text-[11px] py-1 border-b border-gray-50">
