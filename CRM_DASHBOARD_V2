        const commTag=r.commType?commBadgeMap[r.commType]||''  :'';
        const typeBtn=`<button onclick="openActionDetail('${r.type.replace(/'/g,"\\'")}',${r.count})" class="action-type-btn px-2 py-1 rounded text-[11px] font-black border border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-600 hover:text-white transition cursor-pointer whitespace-nowrap" title="클릭하여 세부 분석">${r.type} 🔍</button>`;
