    currentPanelActionType = null;
    currentSubCat = null;
    document.querySelectorAll('#dropRSubCat label.subcat-clickable').forEach(l => l.classList.remove('subcat-active'));
    document.getElementById('panelHeaderTitle').textContent = '🔍 조치유형 세부 분석';
    document.getElementById('panelModeBadge').classList.add('hidden');
    document.getElementById('panelCloseBtn').classList.add('hidden');
    document.getElementById('panelContent').innerHTML = `
        <div class="flex flex-col items-center justify-center h-full text-center text-gray-400 gap-3">
            <div class="text-4xl">👆</div>
            <p class="text-sm font-bold text-gray-500">테이블의 <span class="text-blue-600">조치유형</span>을<br>클릭하면 세부 분석이<br>표시됩니다</p>
            <p class="text-xs text-gray-400 mt-2">처리내용을 AI가 자동 분류하여<br>핵심 패턴을 보여줍니다</p>
        </div>`;
    document.querySelectorAll('.action-type-btn').forEach(b=>b.classList.remove('ring-2','ring-blue-400','bg-blue-600','text-white'));
}

async function openActionDetail(actionType, totalCount){
    // 같은 버튼 재클릭 시 패널 닫기
    if(currentPanelActionType === actionType){ closePanelDetail(); return; }
    currentPanelActionType = actionType;
    currentSubCat = null;  // 소분류 모드 해제

    // 소분류 강조 해제
    document.querySelectorAll('#dropRSubCat label.subcat-clickable').forEach(l => l.classList.remove('subcat-active'));
    // 패널 헤더 조치유형 모드로
    document.getElementById('panelHeaderTitle').textContent = '🔍 조치유형 세부 분석';
    document.getElementById('panelModeBadge').textContent = '조치유형';
    document.getElementById('panelModeBadge').classList.remove('hidden');

    // 버튼 강조
    document.querySelectorAll('.action-type-btn').forEach(b=>{
        b.classList.remove('ring-2','ring-blue-400','bg-blue-600','text-white');
    });
    document.querySelectorAll('.action-type-btn').forEach(b=>{
        if(b.textContent.trim().startsWith(actionType)) b.classList.add('ring-2','ring-blue-400','bg-blue-600','text-white');
    });

    document.getElementById('panelCloseBtn').classList.remove('hidden');

    // 로딩 표시
    document.getElementById('panelContent').innerHTML = `
        <div class="flex flex-col items-center justify-center h-full gap-3 text-blue-500">
            <div class="text-3xl animate-spin">⚙️</div>
            <p class="text-sm font-bold">패턴 분석 중...</p>
            <p class="text-xs text-gray-400">처리내용 키워드 분류 + AI 보완</p>
        </div>`;

    // 해당 조치유형에 속하는 데이터 수집 — 테이블 필터(결함상태/장비명/소분류/상세원인/자재명) 동시 적용
    const fS=getCheckedValues('r-status-cb'),fE=getCheckedValues('r-equip-cb'),fSC=getCheckedValues('r-subcat-cb'),fC=getCheckedValues('r-cause-cb'),fP=getCheckedValues('r-part-cb');
    const tableFilteredData = filteredData.filter(d=>{
        const status=d.isHW?'HW불량':(d.isInstall?'보완재':'단순안내');
        if(fS.length&&!fS.includes(status))return false;
        if(fE.length&&!fE.includes(d.제품명))return false;
        if(fSC.length&&!fSC.includes(d.소분류||'미분류'))return false;
        if(fC.length&&!fC.includes(d.rootCause))return false;
        if(fP.length&&!fP.includes(d.displayPart))return false;
        return true;
    });
    const targetDocs = tableFilteredData.filter(d => d.actionType === actionType);

    // 1차: 키워드 룰 분류
    const rules = actionPatternRules[actionType] || [];
    const patternCounts = {};
    const unclassified = [];

    rules.forEach(r => patternCounts[r.label] = 0);

    targetDocs.forEach(doc => {
        const txt = doc.풀텍스트 || '';
        let matched = false;
        for(const rule of rules){
            if(rule.keywords.some(kw => txt.includes(kw))){
                patternCounts[rule.label]++;
                matched = true;
                break;
            }
        }
        if(!matched) unclassified.push(txt);
    });

    // 분류된 건수 합계
    const classifiedCount = Object.values(patternCounts).reduce((a,b)=>a+b,0);
    const unclassifiedCount = unclassified.length;

    // 2차: 미분류가 있으면 AI 호출
    let aiPatterns = {};
    if(unclassifiedCount > 0 && unclassifiedCount <= 80){
        try {
            const sampleTexts = unclassified.slice(0,40).map((t,i)=>`${i+1}. ${t.slice(0,120)}`).join('\n');
            const resp = await fetch('https://api.anthropic.com/v1/messages',{
                method:'POST',
                headers:{'Content-Type':'application/json'},
                body: JSON.stringify({
                    model:'claude-sonnet-4-20250514',
                    max_tokens:2000,
                    system:`당신은 현장 서비스 리포트 분석 전문가입니다.
아래는 조치유형이 "${actionType}"인 AS 처리내용 텍스트 목록입니다.
이 텍스트들을 읽고 실제로 어떤 세부 작업/원인이었는지를 3~7개의 핵심 패턴으로 분류하고
각 패턴에 해당하는 건수를 반드시 JSON으로만 답하세요.
절대로 JSON 외 다른 텍스트, 마크다운, 백틱을 포함하지 마세요.
반드시 첫 글자가 { 이고 마지막 글자가 } 인 순수 JSON만 출력하세요.
형식(예시): {"와이파이 비밀번호 재입력": 5, "연결 끊김 후 재부팅": 3, "기타": 2}
패턴명은 15자 이내의 한국어 명사구로 간결하게 작성하세요.`,
                    messages:[{role:'user',content:`처리내용 샘플 (총 ${unclassifiedCount}건 중 최대 40건):\n${sampleTexts}`}]
                })
            });
            const data = await resp.json();
            const raw = data.content?.find(c=>c.type==='text')?.text || '{}';
            const clean = raw.replace(/```json|```/g,'').trim();
            // JSON만 추출 (앞뒤 불필요한 텍스트 제거)
            const jsonMatch = clean.match(/\{[\s\S]*\}/);
            aiPatterns = jsonMatch ? JSON.parse(jsonMatch[0]) : {};
        } catch(e){ aiPatterns = {'기타(미분류)': unclassifiedCount}; }
    } else if(unclassifiedCount > 80){
        aiPatterns = {'기타(미분류)': unclassifiedCount};
    }

    // 최종 집계 합산
    const finalMap = {...patternCounts};
    Object.entries(aiPatterns).forEach(([k,v])=>{
        finalMap[k] = (finalMap[k]||0) + v;
    });

    // 0건 제거 + 정렬
    const sorted = Object.entries(finalMap).filter(([,v])=>v>0).sort((a,b)=>b[1]-a[1]);
    const maxVal = sorted.length > 0 ? sorted[0][1] : 1;

    const aiUsed = unclassifiedCount > 0 && unclassifiedCount <= 80;
    const barColors = ['#2563eb','#3b82f6','#60a5fa','#93c5fd','#bfdbfe','#dbeafe'];

    // 기타 비율 경고 임계값
    const etcEntry = sorted.find(([l])=>l.includes('기타')||l.includes('미분류'));
    const etcCount = etcEntry ? etcEntry[1] : 0;
    const etcPct = targetDocs.length > 0 ? Math.round(etcCount/targetDocs.length*100) : 0;
    const showEtcWarning = etcPct >= 30;

    // 미분류 원문 샘플 저장 (기타 클릭용)
    window._unclassifiedSamples = unclassified.slice(0, 20);
    window._unclassifiedTotal = unclassifiedCount;

    document.getElementById('panelContent').innerHTML = `
        <div class="space-y-1">
            <div class="flex items-center justify-between mb-3">
                <div>
                    <p class="text-[13px] font-black text-gray-800">${actionType}</p>
                    <p class="text-[11px] text-gray-500">총 <span class="font-black text-blue-600">${targetDocs.length}건</span> 분석</p>
                </div>
                <span class="text-[10px] px-2 py-1 rounded-full font-bold ${aiUsed?'bg-purple-100 text-purple-700':'bg-green-100 text-green-700'}">${aiUsed?'🤖 AI 보완':'✅ 키워드 분류'}</span>
            </div>

            ${showEtcWarning ? `
            <div class="bg-amber-50 border border-amber-300 rounded-lg px-3 py-2 mb-3 flex gap-2 items-start">
                <span class="text-amber-500 text-sm mt-0.5">⚠️</span>
                <div>
                    <p class="text-[11px] font-black text-amber-700">미분류 비율 ${etcPct}% — 높음</p>
                    <p class="text-[10px] text-amber-600 mt-0.5">처리내용 입력이 부실한 건이 많습니다.<br>아래 <span class="font-black">기타</span>를 클릭해 원문을 확인하세요.</p>
                </div>
            </div>` : ''}

            <div class="space-y-2" id="patternBarList">
                ${sorted.slice(0,20).map(([label,count],i)=>{
                    const pct = Math.round(count/targetDocs.length*100);
                    const color = barColors[Math.min(i, barColors.length-1)];
                    const isEtc = label.includes('기타') || label.includes('미분류');
                    return `
                    <div class="${isEtc ? 'cursor-pointer hover:bg-amber-50 rounded-lg p-1 -mx-1 transition group' : ''}"
                         ${isEtc ? `onclick="toggleEtcSamples(this)"` : ''}>
                        <div class="flex justify-between items-start mb-1 gap-1">
                            <span class="text-[11px] font-bold leading-snug flex-1 min-w-0 break-words ${isEtc ? 'text-amber-700 group-hover:text-amber-900' : 'text-gray-700'}">
                                ${isEtc ? `<span class="mr-1">📋</span>` : ''}${label}
                                ${isEtc ? `<span class="text-[9px] text-amber-500 font-normal ml-1">클릭하여 원문 보기 ▼</span>` : ''}
                            </span>
                            <span class="text-[12px] font-black shrink-0 ${isEtc ? 'text-amber-600' : 'text-blue-700'}">${count}건</span>
                        </div>
                        <div class="w-full bg-gray-100 rounded-full h-3 relative overflow-hidden">
                            <div class="h-3 rounded-full flex items-center justify-end pr-1.5 transition-all duration-700"
                                 style="width:${pct}%;background:${isEtc?'#f59e0b':color};">
                                <span class="text-white text-[9px] font-black">${pct}%</span>
                            </div>
                        </div>
                        ${isEtc ? `<div class="etc-samples hidden mt-2 space-y-1.5"></div>` : ''}
                    </div>`;
                }).join('')}
                ${sorted.length > 20 ? `<p class="text-[10px] text-gray-400 text-center mt-1">+ ${sorted.length-20}개 항목 더 있음</p>` : ''}
            </div>
            ${aiUsed?`<p class="text-[10px] text-purple-500 mt-3 text-center">🤖 미분류 ${unclassifiedCount}건은 AI가 자동 보완</p>`:''}
        </div>`;
}
/* ═══════════════════════════════════════════════════
   기타(미분류) 원문 샘플 토글
   ═══════════════════════════════════════════════════ */
function toggleEtcSamples(container) {
    const samplesDiv = container.querySelector('.etc-samples');
    if (!samplesDiv) return;

    const isOpen = !samplesDiv.classList.contains('hidden');

    if (isOpen) {
        samplesDiv.classList.add('hidden');
        const arrow = container.querySelector('.etc-arrow');
        if (arrow) arrow.textContent = '▼';
        return;
    }

    // 펼치기
    samplesDiv.classList.remove('hidden');
    const arrow = container.querySelector('.etc-arrow');
    if (arrow) arrow.textContent = '▲';

    const samples = window._unclassifiedSamples || [];
    const total   = window._unclassifiedTotal  || 0;

    if (!samples.length) {
        samplesDiv.innerHTML = `<p class="text-[11px] text-gray-400 italic px-2">원문 데이터가 없습니다.</p>`;
        return;
    }

    // 내용 길이 기준으로 "부실" 판단 (30자 미만)
    const isEmpty  = t => !t || t.trim().length < 15;
    const emptyCount = samples.filter(t => isEmpty(t)).length;

    samplesDiv.innerHTML = `
        <div class="bg-white border border-amber-200 rounded-lg overflow-hidden">
            <div class="bg-amber-50 px-3 py-1.5 border-b border-amber-200 flex justify-between items-center">
                <span class="text-[10px] font-black text-amber-700">📄 처리내용 원문 샘플 (최대 20건 / 전체 ${total}건)</span>
                ${emptyCount > 0
                    ? `<span class="text-[10px] bg-red-100 text-red-600 font-black px-1.5 py-0.5 rounded">⚠️ 부실입력 ${emptyCount}건</span>`
                    : `<span class="text-[10px] bg-green-100 text-green-700 font-black px-1.5 py-0.5 rounded">✅ 입력 양호</span>`
                }
            </div>
            <div class="divide-y divide-amber-50">
                ${samples.map((txt, i) => {
                    const display = txt ? txt.trim() : '';
                    const poor    = isEmpty(txt);
                    return `
                    <div class="px-3 py-2 flex gap-2 items-start ${poor ? 'bg-red-50' : 'bg-white'}">
                        <span class="text-[10px] font-black shrink-0 mt-0.5 ${poor ? 'text-red-400' : 'text-gray-400'}">${i+1}</span>
                        <span class="text-[11px] leading-relaxed break-words min-w-0 flex-1 ${poor ? 'text-red-400 italic' : 'text-gray-700'}">
                            ${poor ? '(내용 없음 또는 너무 짧음)' : display}
                        </span>
                    </div>`;
                }).join('')}
            </div>
            ${total > 20 ? `<div class="bg-amber-50 px-3 py-1.5 text-center text-[10px] text-amber-600 font-bold border-t border-amber-200">+ ${total - 20}건 더 있음</div>` : ''}
        </div>
        ${emptyCount > 0 ? `
        <div class="mt-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2">
            <p class="text-[10px] font-black text-red-700">💡 개선 제안</p>
            <p class="text-[10px] text-red-600 mt-0.5">샘플 중 <strong>${emptyCount}건</strong>이 내용 미입력 상태입니다.<br>처리내용 입력 기준을 수립하면 분류 정확도가 높아집니다.</p>
        </div>` : ''}`;
}
</script>
