function classifyCatSub(d, catKey) {
    const rules = catSubRules[catKey]; if(!rules) return 'etc';
    const sub = (d.소분류 || '').toLowerCase(); const txt = (d.풀텍스트 || '').toLowerCase(); const parts = d.실제부품목록.map(p => p.toLowerCase()).join(' ');
    for(const [key, rule] of Object.entries(rules.items)){
        if(key === 'etc') continue;
        if(rule.subMatch.some(s => sub.includes(s.toLowerCase())) || (rule.textMatch||[]).some(s => txt.includes(s.toLowerCase())) || (rule.partMatch.length > 0 && rule.partMatch.some(p => new RegExp(p,'i').test(parts)))) return key;
    }
    return 'etc';
}

function renderCatSubPanel(catKey, data) {
    const rules = catSubRules[catKey]; if(!rules) return;
    const catData = data.filter(d => d.메타카테고리 === catKey);
    const panel = document.getElementById('cat-sub-panel-' + catKey); if(!panel) return;
    panel.querySelector('.cat-sub-total').textContent = '총 ' + catData.length + '건';

    const counts = {}, hwCounts = {}, subDetails = {};
    Object.keys(rules.items).forEach(k => { counts[k]=0; hwCounts[k]=0; subDetails[k]={}; });
    catData.forEach(d => {
        const key = classifyCatSub(d, catKey);
        counts[key]++; if(d.isHW) hwCounts[key]++;
        subDetails[key][d.소분류 || '미분류'] = (subDetails[key][d.소분류 || '미분류']||0) + 1;
    });
    window['_catSubData_' + catKey] = { counts, hwCounts, subDetails, total: catData.length };

    panel.querySelector('.cat-sub-cards').innerHTML = Object.entries(rules.items).map(([key, item]) => {
        const cnt = counts[key] || 0; const hwPct = cnt > 0 ? Math.round((hwCounts[key] || 0)/cnt*100) : 0;
        const isSelected = trendState.subOverlay.has(key);
        const cardStyle = isSelected ? `border-color:${item.color};background:${item.color}10;padding:8px;border-radius:6px;outline:1px solid ${item.color};transform:scale(1.02);cursor:pointer;` : `border-color:${item.color}30;background:#fff;padding:8px;border-radius:6px;border:1px solid #e2e8f0;cursor:pointer;`;
        return `<div data-drill-key="${key}" style="${cardStyle}" onclick="filterCatSub('${catKey}','${key}')">
            <div style="font-size:10px;font-weight:900;color:${item.color};margin-bottom:2px;" class="truncate">${item.label}</div>
            <div style="font-size:16px;font-weight:900;color:#1e293b;line-height:1;">${cnt}<span style="font-size:9px;color:#94a3b8;margin-left:2px;">건</span></div>
            <div style="display:flex; justify-content:space-between; margin-top:4px;">
            <div style="font-size:9px;color:#64748b;">비중 ${catData.length > 0 ? Math.round(cnt/catData.length*100) : 0}%</div>
            <div style="font-size:9px;font-weight:800;color:#ef4444;">HW ${hwPct}%</div>
            </div></div>`;
    }).join('');
    panel.querySelector('.cat-sub-table').classList.add('hidden');
}

function filterCatSub(catKey, itemKey) {
    const rules = catSubRules[catKey]; const data = window['_catSubData_' + catKey]; if(!rules || !data) return;
    const panel = document.getElementById('cat-sub-panel-' + catKey); if(!panel) return;
