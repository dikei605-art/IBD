function classifyCat3Sub(d) {
    const sub = (d.소분류 || '').toLowerCase(); const parts = d.실제부품목록.map(p => p.toLowerCase()).join(' ');
    for (const [key, rule] of Object.entries(cat3SubRules)) {
        if (rule.subMatch.some(s => sub.includes(s)) || (rule.partMatch.length > 0 && rule.partMatch.some(p => new RegExp(p,'i').test(parts)))) return key;
    }
    return 'etc';
}

