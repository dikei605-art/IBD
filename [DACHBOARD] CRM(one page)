const _productColorCache = {};
function getProductColor(productName) { if (_productColorCache[productName] !== undefined) return _productColorCache[productName]; const color = lineColors[Object.keys(_productColorCache).length % lineColors.length]; _productColorCache[productName] = color; return color; }
function resetProductColors() { Object.keys(_productColorCache).forEach(k => delete _productColorCache[k]); }
