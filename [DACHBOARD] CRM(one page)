function setSymptomFilter(cat){
    const allCats = ['cat1','cat2','cat3','cat4','cat5','cat6','cat7','cat8'];
    state.drillSubs = new Map(); 
    trendState.subOverlay.clear(); 

    if(state.symptom===cat){
        state.symptom=null;
        allCats.forEach(c => {
            if(c==='cat3'){ document.getElementById('cat3-sub-panel').classList.add('hidden'); }
            else { const pp = document.getElementById('cat-sub-panel-'+c); if(pp) pp.classList.add('hidden'); }
        });
        trendState.selected.delete(cat);
        if(trendState.tab === 'cat') renderTrendCheckboxes();
    } else {
        state.symptom=cat;
        allCats.forEach(c => {
            if(c==='cat3'){ document.getElementById('cat3-sub-panel').classList.add('hidden'); }
            else { const pp = document.getElementById('cat-sub-panel-'+c); if(pp) pp.classList.add('hidden'); }
        });
