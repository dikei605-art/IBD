<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CRM Dashboard - Modern One-Page</title>
    <script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* ─── 원페이지 고정 & 모던 SaaS 테마 설정 ─── */
        :root {
            --bg-body: #f1f5f9;
            --bg-panel: #ffffff;
            --border-panel: #e2e8f0;
            --shadow-panel: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --radius-panel: 12px;
            --text-main: #1e293b;
            --text-sub: #64748b;
        }

        body { 
            margin: 0; padding: 0; width: 100vw; height: 100vh; overflow: hidden; 
            background-color: var(--bg-body); color: var(--text-main);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        /* 내부 스크롤바 디자인 */
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background-color: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background-color: #94a3b8; }

        /* 패널 공통 스타일 */
        .panel {
            background-color: var(--bg-panel); border: 1px solid var(--border-panel);
            box-shadow: var(--shadow-panel); border-radius: var(--radius-panel);
            display: flex; flex-direction: column; overflow: hidden;
        }
        .panel-header {
            font-size: 13px; font-weight: 800; padding: 10px 14px; 
            border-bottom: 1px solid var(--border-panel); background: #f8fafc;
            display: flex; justify-content: space-between; align-items: center; flex-shrink: 0;
        }
        .panel-content { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 12px; position: relative; }

        /* 증상 카드 */
        .symptom-card { 
            border: 1px solid var(--border-panel); border-radius: 8px; padding: 8px; 
            cursor: pointer; transition: all 0.2s; background: #fff;
            display: flex; flex-direction: column; justify-content: space-between;
        }
        .symptom-card:hover { border-color: #3b82f6; box-shadow: 0 2px 4px rgba(59,130,246,0.1); }
        .active-symptom { border-color: #2563eb !important; background-color: #eff6ff !important; box-shadow: inset 0 0 0 1px #2563eb !important; }

        /* 차트 컨테이너 필수 속성 */
        .chart-container { position: relative; width: 100%; height: 100%; min-height: 0; }
        canvas { display: block; width: 100% !important; height: 100% !important; }

        /* ─── 다중 선택 드롭다운 (절대 배치) ─── */
        .ms-wrap { position: relative; width: 100%; min-width: 140px; }
        .ms-btn {
            width: 100%; display: flex; justify-content: space-between; align-items: center; gap: 4px;
            background: #fff; border: 1px solid #cbd5e1; padding: 6px 10px; border-radius: 6px;
            font-size: 12px; font-weight: 700; color: #334155; cursor: pointer; user-select: none;
        }
        .ms-btn:hover { background: #f8fafc; border-color: #94a3b8; }
        .ms-btn.ms-open { border-radius: 6px 6px 0 0; border-color: #2563eb; color: #1d4ed8; }
        .ms-btn.has-selection:not(.ms-open) { border-color: #3b82f6; background: #f0f7ff; color: #1e40af; }
        .ms-btn .sel-badge { display: none; background: #2563eb; color: white; font-size: 10px; padding: 1px 5px; border-radius: 10px; }
        .ms-btn.has-selection .sel-badge { display: inline-block; }
        .ms-btn .btn-label { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-align: left; }
        
        .ms-list {
            display: none; position: absolute; top: 100%; left: 0; width: max-content; min-width: 100%; max-width: 300px;
            max-height: 250px; overflow-y: auto; background: white; z-index: 9999;
            border: 1px solid #2563eb; border-top: none; border-radius: 0 0 6px 6px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
        }
        .ms-list.ms-open { display: block; }
        .ms-list label { display: flex; align-items: center; padding: 6px 10px; cursor: pointer; font-size: 11px; font-weight: 600; border-bottom: 1px solid #f1f5f9; }
        .ms-list label:hover { background: #eff6ff; color: #1d4ed8; }
        .ms-list label.all-lbl { background: #f0fdf4; color: #15803d !important; position: sticky; top: 0; z-index: 10; border-bottom: 2px solid #dcfce7; }
        .ms-list input[type="checkbox"] { margin-right: 6px; }

        /* ─── 탭 집계표 ─── */
        .tab-nav-wrap { display: flex; overflow-x: auto; border-bottom: 2px solid #e2e8f0; flex-shrink: 0; }
        .rn-tab-btn { padding: 8px 12px; font-size: 11px; font-weight: 800; color: #64748b; background: none; border: none; border-bottom: 3px solid transparent; cursor: pointer; white-space: nowrap; display: flex; align-items: center; gap: 4px; margin-bottom: -2px; }
        .rn-tab-btn.active { color: #1d4ed8; border-bottom-color: #2563eb; }
        .rn-tab-count { font-size: 10px; font-weight: 800; padding: 1px 5px; border-radius: 8px; }
        .rn-tab-panel { display: none; height: 100%; overflow-y: auto; }
        .rn-tab-panel.active { display: block; }
        .agg-tbl { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 11px; }
        .agg-tbl th { position: sticky; top: 0; background: #f8fafc; padding: 6px 8px; text-align: left; font-size: 10px; font-weight: 800; color: #64748b; border-bottom: 2px solid #e2e8f0; z-index: 5; }
        .agg-tbl td { padding: 6px 8px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; transition: background-color 0.2s; }
        .agg-cause-main { font-weight: 800; color: #1e293b; }
        .agg-share-bar-wrap { height: 4px; border-radius: 2px; background: #f1f5f9; overflow: hidden; margin-top: 2px; }
        .agg-share-bar-fill { height: 100%; border-radius: 2px; }
        .part-tag-sm { display: inline-flex; align-items: center; font-size: 10px; background: #f1f5f9; padding: 1px 5px; border-radius: 4px; margin: 1px; font-weight: 600; }
        
        .action-type-btn { font-size: 10px; font-weight: 800; padding: 3px 8px; border-radius: 4px; border: 1px solid #bfdbfe; background: #eff6ff; color: #1d4ed8; cursor: pointer; transition: all .15s; white-space: nowrap; }
        .action-type-btn:hover, .action-type-btn.active-btn { background: #2563eb; color: white; border-color: #2563eb; }

        /* AI 패널 내부 스크롤 */
        #actionDetailPanel { display: flex; flex-direction: column; overflow: hidden; }
        #panelContent { overflow-y: auto; flex: 1; padding: 12px; }
        .panel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 8px; }
        .panel-bar-label { font-size: 11px; font-weight: 700; color: #374151; margin-bottom: 2px; }
        .panel-bar-track { height: 6px; background: #f1f5f9; border-radius: 3px; overflow: hidden; }
        .panel-bar-fill  { height: 100%; border-radius: 3px; }
        .panel-bar-meta  { display: flex; justify-content: space-between; margin-top: 2px; font-size: 10px; }
    </style>
</head>
<body class="p-2 md:p-3 flex flex-col gap-3">

    <header class="panel flex-row px-4 py-2 shrink-0 items-center justify-between overflow-visible z-50 h-14" style="border-radius: var(--radius-panel);">
        <div class="flex items-center gap-6">
            <h1 class="text-xl font-black tracking-tight text-blue-700">CRM Fact-Finder</h1>
            <div class="flex items-center gap-2" style="width: 500px;">
                <div class="ms-wrap"><div class="ms-btn" onclick="toggleMs(this)"><span class="btn-label">📅 연도 선택</span><span class="sel-badge">0</span><span class="arr">▼</span></div><div class="ms-list" id="dropGlobalYear"></div></div>
                <div class="ms-wrap"><div class="ms-btn" onclick="toggleMs(this)"><span class="btn-label">🏭 라인업(DNO)</span><span class="sel-badge">0</span><span class="arr">▼</span></div><div class="ms-list" id="dropGlobalDNO"></div></div>
                <div class="ms-wrap"><div class="ms-btn" onclick="toggleMs(this)"><span class="btn-label">📊 장비 제품</span><span class="sel-badge">0</span><span class="arr">▼</span></div><div class="ms-list" id="dropGlobalProd"></div></div>
                <div class="ms-wrap"><div class="ms-btn" onclick="toggleMs(this)"><span class="btn-label">📋 대분류 증상</span><span class="sel-badge">0</span><span class="arr">▼</span></div><div class="ms-list" id="dropGlobalCat"></div></div>
            </div>
        </div>

        <div class="flex items-center gap-4">
            <div id="drillBreadcrumb" class="hidden text-[11px] font-bold text-gray-500 bg-gray-100 px-3 py-1.5 rounded-md flex items-center gap-1"></div>
            <div class="text-xs font-bold text-gray-500">필터링: <span id="totalDocCount" class="text-lg text-blue-600">0</span>건</div>
            <button onclick="resetAll()" class="bg-red-50 text-red-600 border border-red-200 px-3 py-1.5 rounded-md text-xs font-black hover:bg-red-100">🔄 초기화</button>
            <input type="file" id="excelFile" accept=".xlsx,.xls,.csv" class="hidden">
            <button onclick="document.getElementById('excelFile').click()" class="bg-blue-600 text-white px-4 py-1.5 rounded-md text-xs font-black hover:bg-blue-700 shadow-sm">📁 데이터 로드</button>
        </div>
    </header>

    <main class="flex-1 grid grid-cols-12 gap-3 min-h-0">

        <div class="col-span-12 lg:col-span-3 flex flex-col gap-3 min-h-0">
            <div class="panel h-[40%] shrink-0">
                <div class="panel-header">🚨 불량 대분류 <span class="text-[10px] font-normal text-gray-400 ml-2">(클릭 필터)</span></div>
                <div class="panel-content grid grid-cols-2 gap-2 p-2">
                    <div id="btn-cat1" class="symptom-card" onclick="setSymptomFilter('cat1')">
                        <div class="text-[11px] font-black text-gray-700 truncate">1️⃣ 측정 결함</div>
                        <div class="flex items-end justify-between mt-1">
                            <span class="text-lg font-black text-blue-600 leading-none"><span id="kpi-cat1-tot">0</span><span class="text-[10px] text-gray-400 ml-0.5">건</span></span>
                            <span class="text-[9px] font-bold text-red-500 bg-red-50 px-1 rounded">HW <span id="kpi-cat1-rate">0%</span></span>
                        </div>
                    </div>
                    <div id="btn-cat2" class="symptom-card" onclick="setSymptomFilter('cat2')">
                        <div class="text-[11px] font-black text-gray-700 truncate">2️⃣ 체중/영점</div>
                        <div class="flex items-end justify-between mt-1">
                            <span class="text-lg font-black text-emerald-600 leading-none"><span id="kpi-cat2-tot">0</span><span class="text-[10px] text-gray-400 ml-0.5">건</span></span>
                            <span class="text-[9px] font-bold text-red-500 bg-red-50 px-1 rounded">HW <span id="kpi-cat2-rate">0%</span></span>
                        </div>
                    </div>
                    <div id="btn-cat3" class="symptom-card" onclick="setSymptomFilter('cat3')">
                        <div class="text-[11px] font-black text-gray-700 truncate">3️⃣ 통신/네트워크</div>
                        <div class="flex items-end justify-between mt-1">
                            <span class="text-lg font-black text-purple-600 leading-none"><span id="kpi-cat3-tot">0</span><span class="text-[10px] text-gray-400 ml-0.5">건</span></span>
                            <span class="text-[9px] font-bold text-red-500 bg-red-50 px-1 rounded">HW <span id="kpi-cat3-rate">0%</span></span>
                        </div>
                    </div>
                    <div id="btn-cat4" class="symptom-card" onclick="setSymptomFilter('cat4')">
                        <div class="text-[11px] font-black text-gray-700 truncate">4️⃣ 디스플레이</div>
                        <div class="flex items-end justify-between mt-1">
                            <span class="text-lg font-black text-orange-500 leading-none"><span id="kpi-cat4-tot">0</span><span class="text-[10px] text-gray-400 ml-0.5">건</span></span>
                            <span class="text-[9px] font-bold text-red-500 bg-red-50 px-1 rounded">HW <span id="kpi-cat4-rate">0%</span></span>
                        </div>
                    </div>
                    <div id="btn-cat5" class="symptom-card" onclick="setSymptomFilter('cat5')">
                        <div class="text-[11px] font-black text-gray-700 truncate">5️⃣ 전원/외부기기</div>
                        <div class="flex items-end justify-between mt-1">
                            <span class="text-lg font-black text-cyan-600 leading-none"><span id="kpi-cat5-tot">0</span><span class="text-[10px] text-gray-400 ml-0.5">건</span></span>
                            <span class="text-[9px] font-bold text-red-500 bg-red-50 px-1 rounded">HW <span id="kpi-cat5-rate">0%</span></span>
                        </div>
                    </div>
                    <div id="btn-cat6" class="symptom-card" onclick="setSymptomFilter('cat6')">
                        <div class="text-[11px] font-black text-gray-700 truncate">6️⃣ 고객문의</div>
                        <div class="flex items-end justify-between mt-1">
                            <span class="text-lg font-black text-slate-600 leading-none"><span id="kpi-cat6-tot">0</span><span class="text-[10px] text-gray-400 ml-0.5">건</span></span>
                            <span class="text-[9px] font-bold text-red-500 bg-red-50 px-1 rounded">HW <span id="kpi-cat6-rate">0%</span></span>
                        </div>
                    </div>
                    <div id="btn-cat7" class="symptom-card" onclick="setSymptomFilter('cat7')">
                        <div class="text-[11px] font-black text-red-700 truncate">🚨 7️⃣ 장비동작이상</div>
                        <div class="flex items-end justify-between mt-1">
                            <span class="text-lg font-black text-red-600 leading-none"><span id="kpi-cat7-tot">0</span><span class="text-[10px] text-gray-400 ml-0.5">건</span></span>
                            <span class="text-[9px] font-bold text-red-500 bg-red-50 px-1 rounded">HW <span id="kpi-cat7-rate">0%</span></span>
                        </div>
                    </div>
                    <div id="btn-cat8" class="symptom-card" onclick="setSymptomFilter('cat8')">
                        <div class="text-[11px] font-black text-yellow-700 truncate">8️⃣ 노이즈(환경)</div>
                        <div class="flex items-end justify-between mt-1">
                            <span class="text-lg font-black text-yellow-600 leading-none"><span id="kpi-cat8-tot">0</span><span class="text-[10px] text-gray-400 ml-0.5">건</span></span>
                            <span class="text-[9px] font-bold text-orange-500 bg-orange-50 px-1 rounded">보완 <span id="kpi-cat8-rate">0%</span></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel flex-1 min-h-0">
                <div class="panel-header">🔍 세부 분류 <span class="text-[10px] text-gray-400 font-normal ml-2">(대분류 선택시 표시)</span></div>
                <div class="panel-content p-2 space-y-2">
                    <div id="cat3-sub-panel" class="hidden">
                        <div class="flex items-center justify-between mb-2 px-1">
                            <span class="text-purple-700 font-black text-[12px]">📶 통신/네트워크</span>
                            <span id="cat3-sub-total" class="text-[10px] font-black"></span>
                        </div>
                        <div id="cat3-sub-cards" class="grid grid-cols-2 gap-2 mb-2"></div>
                        <div id="cat3-sub-table" class="hidden mt-2 border border-gray-200 rounded overflow-hidden">
                            <table class="agg-tbl">
                                <thead><tr><th>소분류</th><th style="text-align:right">건수</th><th>비중</th></tr></thead>
                                <tbody id="cat3-sub-table-body"></tbody>
                            </table>
                        </div>
                    </div>

                    <div id="cat-sub-panel-cat1" class="hidden"><div class="flex items-center justify-between mb-2 px-1"><span class="font-black text-[12px] text-blue-600">📏 측정 결함</span><span class="cat-sub-total text-[10px] font-black"></span></div><div class="cat-sub-cards grid grid-cols-2 gap-2 mb-2"></div><div class="cat-sub-table hidden mt-2 border border-gray-200 rounded overflow-hidden"><table class="agg-tbl"><thead><tr><th>소분류</th><th style="text-align:right">건수</th><th>비중</th></tr></thead><tbody class="cat-sub-table-body"></tbody></table></div></div>
                    <div id="cat-sub-panel-cat2" class="hidden"><div class="flex items-center justify-between mb-2 px-1"><span class="font-black text-[12px] text-emerald-600">⚖️ 체중/영점 이상</span><span class="cat-sub-total text-[10px] font-black"></span></div><div class="cat-sub-cards grid grid-cols-2 gap-2 mb-2"></div><div class="cat-sub-table hidden mt-2 border border-gray-200 rounded overflow-hidden"><table class="agg-tbl"><thead><tr><th>소분류</th><th style="text-align:right">건수</th><th>비중</th></tr></thead><tbody class="cat-sub-table-body"></tbody></table></div></div>
                    <div id="cat-sub-panel-cat4" class="hidden"><div class="flex items-center justify-between mb-2 px-1"><span class="font-black text-[12px] text-orange-500">🖥️ 디스플레이</span><span class="cat-sub-total text-[10px] font-black"></span></div><div class="cat-sub-cards grid grid-cols-2 gap-2 mb-2"></div><div class="cat-sub-table hidden mt-2 border border-gray-200 rounded overflow-hidden"><table class="agg-tbl"><thead><tr><th>소분류</th><th style="text-align:right">건수</th><th>비중</th></tr></thead><tbody class="cat-sub-table-body"></tbody></table></div></div>
                    <div id="cat-sub-panel-cat5" class="hidden"><div class="flex items-center justify-between mb-2 px-1"><span class="font-black text-[12px] text-cyan-600">⚡ 전원/외부기기</span><span class="cat-sub-total text-[10px] font-black"></span></div><div class="cat-sub-cards grid grid-cols-2 gap-2 mb-2"></div><div class="cat-sub-table hidden mt-2 border border-gray-200 rounded overflow-hidden"><table class="agg-tbl"><thead><tr><th>소분류</th><th style="text-align:right">건수</th><th>비중</th></tr></thead><tbody class="cat-sub-table-body"></tbody></table></div></div>
                    <div id="cat-sub-panel-cat6" class="hidden"><div class="flex items-center justify-between mb-2 px-1"><span class="font-black text-[12px] text-slate-500">👤 고객문의</span><span class="cat-sub-total text-[10px] font-black"></span></div><div class="cat-sub-cards grid grid-cols-2 gap-2 mb-2"></div><div class="cat-sub-table hidden mt-2 border border-gray-200 rounded overflow-hidden"><table class="agg-tbl"><thead><tr><th>소분류</th><th style="text-align:right">건수</th><th>비중</th></tr></thead><tbody class="cat-sub-table-body"></tbody></table></div></div>
                    <div id="cat-sub-panel-cat7" class="hidden"><div class="flex items-center justify-between mb-2 px-1"><span class="font-black text-[12px] text-red-600">⚙️ 장비동작이상</span><span class="cat-sub-total text-[10px] font-black"></span></div><div class="cat-sub-cards grid grid-cols-2 gap-2 mb-2"></div><div class="cat-sub-table hidden mt-2 border border-gray-200 rounded overflow-hidden"><table class="agg-tbl"><thead><tr><th>소분류</th><th style="text-align:right">건수</th><th>비중</th></tr></thead><tbody class="cat-sub-table-body"></tbody></table></div></div>
                    <div id="cat-sub-panel-cat8" class="hidden"><div class="flex items-center justify-between mb-2 px-1"><span class="font-black text-[12px] text-yellow-600">🌩️ 노이즈</span><span class="cat-sub-total text-[10px] font-black"></span></div><div class="cat-sub-cards grid grid-cols-2 gap-2 mb-2"></div><div class="cat-sub-table hidden mt-2 border border-gray-200 rounded overflow-hidden"><table class="agg-tbl"><thead><tr><th>소분류</th><th style="text-align:right">건수</th><th>비중</th></tr></thead><tbody class="cat-sub-table-body"></tbody></table></div></div>
                    
                    <div id="subcatGuide" class="h-full flex flex-col items-center justify-center text-gray-400 text-[11px] font-bold">
                        <div>👆 위에서 대분류 카드를 클릭하세요</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-span-12 lg:col-span-6 flex flex-col gap-3 min-h-0">
            <div class="panel h-[45%] shrink-0 flex flex-col">
                <div class="panel-header" style="padding: 6px 14px;">
                    <span id="titleTrend">📈 발생 추이</span>
                    <div class="flex items-center gap-2">
                        <div class="flex bg-gray-100 rounded border border-gray-200 overflow-hidden">
                            <button class="trend-period-btn text-[10px] font-bold px-2 py-1 bg-white text-blue-600 shadow-sm" onclick="switchTrendPeriod('monthly')">월별</button>
                            <button class="trend-period-btn text-[10px] font-bold px-2 py-1 text-gray-500" onclick="switchTrendPeriod('weekly')">주별</button>
                            <button class="trend-period-btn text-[10px] font-bold px-2 py-1 text-gray-500" onclick="switchTrendPeriod('yearly')">연별</button>
                        </div>
                        <div class="flex bg-gray-100 rounded border border-gray-200 overflow-hidden">
                            <button id="trend-tab-product" class="text-[10px] font-bold px-2 py-1 bg-white text-blue-600 shadow-sm" onclick="switchTrendTab('product')">제품별</button>
                            <button id="trend-tab-cat" class="text-[10px] font-bold px-2 py-1 text-gray-500" onclick="switchTrendTab('cat')">불량구분</button>
                            <button id="trend-tab-stacked" class="text-[10px] font-bold px-2 py-1 text-gray-500" onclick="switchTrendTab('stacked')">누적막대</button>
