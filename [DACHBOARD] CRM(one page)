function renderTabView(data) {
    if (!data) data = window._currentDisplayData || filteredData;
    const nav = document.getElementById('rnTabNav'); const panels = document.getElementById('rnTabPanels');
    if (!nav || !panels) return;

    const activeBtn = nav.querySelector('.rn-tab-btn.active'); const activeStatus = activeBtn ? activeBtn.dataset.status : null;
    const causeMap = {};
    data.forEach(d => {
        const status = d.isHW ? 'HW불량' : (d.isInstall ? '보완재' : '단순안내'); const key = status + '||' + d.rootCause + '||' + d.actionType;
        if (!causeMap[key]) { causeMap[key] = { status, cause: d.rootCause, actionType: d.actionType, metaCat: d.메타카테고리 || '미분류_기타', repLabel: (classifyPartsAll(d.실제부품목록) || {}).label || null, count: 0, soloCount: 0, comboCount: 0, partCounts: {}, companionCats: {} }; }
        causeMap[key].count++;
        if (d.isHW || d.isInstall) {
            const repLabel = causeMap[key].repLabel; let hasCompanion = false;
            d.실제부품목록.forEach(p => { if (!p) return; const pLabel = classifyPart(p).label; if (pLabel === repLabel) { causeMap[key].partCounts[p] = (causeMap[key].partCounts[p] || 0) + 1; } else { hasCompanion = true; causeMap[key].companionCats[pLabel] = (causeMap[key].companionCats[pLabel] || 0) + 1; } });
            if (hasCompanion) causeMap[key].comboCount++; else causeMap[key].soloCount++;
        }
    });

    const allItems = Object.values(causeMap).sort((a, b) => b.count - a.count); const statusTotals = {};
    allItems.forEach(it => { statusTotals[it.status] = (statusTotals[it.status] || 0) + it.count; });
    const activeTabs = tabConfig.filter(t => statusTotals[t.status] > 0);
    if (!activeTabs.length) { nav.innerHTML = ''; panels.innerHTML = '<div class="text-center p-4 text-xs text-gray-400">데이터가 없습니다</div>'; return; }

    const restoreStatus = activeStatus && activeTabs.some(t => t.status === activeStatus) ? activeStatus : activeTabs[0].status;

    nav.innerHTML = activeTabs.map((t) => {
        const cnt = statusTotals[t.status] || 0; const isActive = t.status === restoreStatus;
        return `<button class="rn-tab-btn ${isActive ? 'active' : ''}" data-status="${t.status}" onclick="rnSwitchTab(this, 'rn-panel-${t.status}')">${t.label} <span class="rn-tab-count" style="background:${t.barBg};color:${t.tagColor};">${cnt}건</span></button>`;
    }).join('');

    panels.innerHTML = activeTabs.map((t) => {
        const items = allItems.filter(it => it.status === t.status); const total = statusTotals[t.status] || 1;
        const rows = items.map(item => {
            const pct = Math.round(item.count / total * 100); const cm = catMeta[item.metaCat] || catMeta['미분류_기타'];
            const catBadge = `<span style="font-size:9px;font-weight:700;padding:1px 4px;border-radius:4px;background:${cm.bg};color:${cm.color};white-space:nowrap;">${cm.label}</span>`;
            const topParts = Object.entries(item.partCounts).sort((a, b) => b[1] - a[1]).slice(0, 3);
            const partsHTML = topParts.length > 0 ? topParts.map(([name, cnt]) => `<span class="part-tag-sm">${name}<span style="color:#94a3b8;font-size:8px;margin-left:2px;">${cnt}</span></span>`).join('') : `<span style="color:#cbd5e1;font-size:9px;">없음</span>`;
            let companionHTML = ''; if (item.comboCount > 0) companionHTML = `<div style="font-size:9px;color:#f97316;font-weight:700;margin-top:2px;">+동반 ${item.comboCount}건</div>`;
            
            const typeBtn = `<button class="action-type-btn" onclick="openActionDetail('${item.actionType.replace(/'/g,"\\'")}', ${item.count}, this)">${item.actionType}</button>`;

            return `<tr>
                <td style="white-space:nowrap;width:15%;">${catBadge}</td>
                <td style="width:30%;"><div class="agg-cause-main text-[11px] leading-tight">${item.cause}</div>${companionHTML}</td>
                <td style="width:30%;">${partsHTML}</td>
                <td style="white-space:nowrap;width:15%;">${typeBtn}</td>
                <td style="width:10%;">
                    <div style="font-weight:900;font-size:12px;color:${t.barColor};">${item.count}</div>
                    <div class="agg-share-bar-wrap"><div class="agg-share-bar-fill" style="width:${pct}%;background:${t.barColor};"></div></div>
                </td>
            </tr>`;
        }).join('');

        return `<div class="rn-tab-panel ${t.status === restoreStatus ? 'active' : ''}" id="rn-panel-${t.status}">
            <table class="agg-tbl"><thead><tr><th>카테고리</th><th>상세 원인</th><th>핵심 자재</th><th>조치유형(클릭)</th><th>건수</th></tr></thead>
            <tbody>${rows || '<tr><td colspan="5" class="text-center p-4">데이터 없음</td></tr>'}</tbody></table></div>`;
    }).join('');
}

