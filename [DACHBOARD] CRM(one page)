const _defaultBtnLabels = { 'g-year-cb': '📅 연도 선택', 'g-dno-cb': '🏭 라인업(DNO)', 'g-prod-cb': '📊 장비 제품', 'g-cat-cb': '📋 대분류 증상' };
const _compactCbClasses = new Set(['g-prod-cb','g-cat-cb']);

function refreshBadge(cbClass) {
    const boxes = document.querySelectorAll('.' + cbClass);
    if (!boxes.length) return;
    const checkedBoxes = Array.from(document.querySelectorAll('.' + cbClass + ':checked'));
    const count = checkedBoxes.length;
    const list  = boxes[0].closest('.ms-list');
    if (!list) return;
    const btn   = list.previousElementSibling;
    if (!btn)  return;
    const badge = btn.querySelector('.sel-badge');
    const labelEl = btn.querySelector('.btn-label');

    if (badge) badge.textContent = count;
    count > 0 ? btn.classList.add('has-selection') : btn.classList.remove('has-selection');

    if (labelEl) {
        if (count === 0) { labelEl.textContent = _defaultBtnLabels[cbClass] || '선택'; } 
        else if (_compactCbClasses.has(cbClass)) {
            const first = checkedBoxes[0].value;
            labelEl.textContent = count === 1 ? first : `${first} 외 ${count - 1}개`;
        } else {
            const vals = checkedBoxes.map(cb => { const lbl = cb.closest('label'); return lbl ? lbl.textContent.trim() : cb.value; });
            labelEl.textContent = vals.join(', ');
        }
    }
}

function renderMultiSelect(containerId, items, cbClass, cbName) {
    const c = document.getElementById(containerId); if (!c) return;
    c.innerHTML = '';
    const al = document.createElement('label'); al.className='all-lbl';
    al.innerHTML=`<input type="checkbox" class="sel-all-${cbClass}" onchange="toggleAll(this,'${cbClass}','${cbName}')"> ☑️ 전체 선택 / 해제`;
    c.appendChild(al);
    items.forEach(item=>{
        const val=typeof item==='object'?item.val:item, txt=typeof item==='object'?item.txt:item;
        const l=document.createElement('label');
        l.innerHTML=`<input type="checkbox" value="${val}" class="${cbClass}" onchange="checkIndividual(this,'sel-all-${cbClass}','${cbName}')"> ${txt}`;
        c.appendChild(l);
    });
}
function toggleAll(allCb, cls, fn) { document.querySelectorAll('.'+cls).forEach(cb=>cb.checked=allCb.checked); refreshBadge(cls); window[fn](); }
function checkIndividual(cb, allCls, fn) {
    const a=document.querySelector('.'+allCls);
    if(a) a.checked=Array.from(document.querySelectorAll('.'+cb.className)).every(c=>c.checked);
    refreshBadge(cb.className.trim().split(/\s+/)[0]);
    window[fn]();
}
function getCheckedValues(cls) { return Array.from(document.querySelectorAll('.'+cls+':checked')).map(cb=>cb.value); }

