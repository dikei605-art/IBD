    document.getElementById('panelHeaderTitle').textContent = '🔍 조치유형 AI 패턴 분석';
    document.getElementById('panelModeBadge').textContent = actionType;
    document.getElementById('panelModeBadge').classList.remove('hidden');
    
    document.getElementById('panelHeaderWrap').classList.remove('bg-blue-50');
    document.getElementById('panelHeaderWrap').classList.add('bg-blue-600');
    document.getElementById('panelHeaderTitle').classList.remove('text-blue-800');
    document.getElementById('panelHeaderTitle').classList.add('text-white');
    document.getElementById('panelCloseBtn').classList.remove('hidden');
    document.getElementById('panelCloseBtn').classList.add('text-white', 'hover:text-blue-200');

    document.querySelectorAll('.agg-tbl tr').forEach(tr => tr.style.backgroundColor = '');
    document.querySelectorAll('.action-type-btn').forEach(b=>{ b.classList.remove('ring-2','ring-blue-400','bg-blue-600','text-white'); });
    
    if(btnElement) {
        btnElement.classList.add('ring-2','ring-blue-400','bg-blue-600','text-white');
        const tr = btnElement.closest('tr');
        if(tr) tr.style.backgroundColor = '#eff6ff'; 
    }

    document.getElementById('panelContent').innerHTML = `<div class="flex flex-col items-center justify-center h-full gap-2 text-blue-500"><div class="text-2xl animate-spin">⚙️</div><p class="text-[11px] font-bold">데이터 분석 중...</p></div>`;

    const targetDocs = (window._currentDisplayData || filteredData).filter(d => d.actionType === actionType);

    const partLabelCounts = {};  
    const noPartsDocs = [];      

    targetDocs.forEach(doc => {
        if(doc.실제부품목록 && doc.실제부품목록.length > 0){
            const rep = classifyPartsAll(doc.실제부품목록); const label = rep ? rep.label : '기타 부품';
            partLabelCounts[label] = (partLabelCounts[label] || 0) + 1;
        } else { noPartsDocs.push(doc); }
    });

    const rules = actionPatternRules[actionType] || [];
    const patCounts = {}; const unclass = [];
    rules.forEach(r => patCounts[r.label] = 0);
    noPartsDocs.forEach(doc => {
        const txt = doc.풀텍스트 || ''; let matched = false;
        for (const rule of rules) { if (rule.keywords.some(kw => txt.includes(kw))) { patCounts[rule.label]++; matched = true; break; } }
        if (!matched) unclass.push(doc.풀텍스트);
    });
    if (unclass.length) patCounts['기타(미분류)'] = unclass.length;
    
    const finalMap = {...partLabelCounts};
    Object.entries(patCounts).forEach(([k,v])=>{ finalMap[k] = (finalMap[k]||0) + v; });

    const sorted = Object.entries(finalMap).filter(([,v])=>v>0).sort((a,b)=>b[1]-a[1]);
    const barColors = ['#2563eb','#3b82f6','#60a5fa','#93c5fd','#bfdbfe','#dbeafe'];

    window._unclassifiedSamples = unclass.slice(0, 20); window._unclassifiedTotal = unclass.length;

    document.getElementById('panelContent').innerHTML = `
        <div class="h-full flex flex-col">
            <div class="flex items-center justify-between mb-3 shrink-0">
                <span class="text-[12px] text-gray-500">총 <span class="font-black text-blue-600">${targetDocs.length}건</span> 분석 결과</span>
            </div>
            <div class="panel-grid flex-1 overflow-y-auto">
                ${sorted.map(([label,count],i)=>{
                    const pct = Math.round(count/targetDocs.length*100);
                    const color = barColors[Math.min(i, barColors.length-1)];
                    const isEtc = label.includes('기타') || label.includes('미분류');
                    return `
                    <div class="mb-2 ${isEtc?'cursor-pointer':''}" ${isEtc?'onclick="toggleEtcSamples(this)"':''}>
                        <div class="panel-bar-label ${isEtc?'text-amber-700':''}">${label}${isEtc?' <span style="font-size:8px;color:#d97706;">▼ 원문보기</span>':''}</div>
                        <div class="panel-bar-track"><div class="panel-bar-fill" style="width:${pct}%;background:${isEtc?'#f59e0b':color};"></div></div>
                        <div class="panel-bar-meta"><span class="font-bold">${count}건</span><span class="text-gray-400">${pct}%</span></div>
                        ${isEtc ? `<div class="etc-samples hidden mt-1 space-y-1"></div>` : ''}
                    </div>`;
                }).join('')}
            </div>
        </div>`;
}

function toggleEtcSamples(container) {
    const samplesDiv = container.querySelector('.etc-samples'); if (!samplesDiv) return;
    const isOpen = !samplesDiv.classList.contains('hidden');
    if (isOpen) { samplesDiv.classList.add('hidden'); return; }

    samplesDiv.classList.remove('hidden');
    const samples = window._unclassifiedSamples || []; const total = window._unclassifiedTotal || 0;
    if (!samples.length) { samplesDiv.innerHTML = `<p class="text-[9px] text-gray-400 italic">원문 데이터가 없습니다.</p>`; return; }

    samplesDiv.innerHTML = `
        <div class="bg-amber-50 border border-amber-200 rounded p-1.5 mt-1 max-h-32 overflow-y-auto">
            <div class="text-[9px] font-black text-amber-700 mb-1 border-b border-amber-200 pb-1">📄 원문 샘플 (최대 20건)</div>
            ${samples.map(txt => `<div class="text-[9px] text-gray-600 mb-0.5 truncate border-b border-amber-100 pb-0.5" title="${txt}">- ${txt||'(내용없음)'}</div>`).join('')}
        </div>`;
}
    </script>
</body>
