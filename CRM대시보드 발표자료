<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CRM Fact-Finder — 기능 소개</title>
<link href="https://cdn.jsdelivr.net/gh/fonts-archive/S-CoreDream/S-CoreDream.css" rel="stylesheet">
<style>
:root {
  --red: #8B2323;
  --red-bg: #F9EDED;
  --red-mid: #b02d2d;
  --black: #111111;
  --gray: #6B7280;
  --gray-light: #F3F4F6;
  --gray-mid: #E5E7EB;
  --gray-dark: #4B5563;
  --white: #FFFFFF;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'S-Core Dream', 'Noto Sans KR', sans-serif;
  font-weight: 400;
  background: #FAFAFA;
  color: var(--black);
  line-height: 1.6;
}

/* ── 섹션 공통 ── */
.section {
  max-width: 1080px;
  margin: 0 auto;
  padding: 80px 48px;
}
.section + .section {
  border-top: 1px solid var(--gray-mid);
}

.sec-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 12px;
}
.sec-title {
  font-size: 32px;
  font-weight: 800;
  color: var(--black);
  line-height: 1.25;
  margin-bottom: 10px;
}
.sec-sub {
  font-size: 15px;
  color: var(--gray);
  margin-bottom: 48px;
  max-width: 640px;
}

/* ── 커버 ── */
.cover {
  background: var(--black);
  padding: 0;
}
.cover-inner {
  max-width: 1080px;
  margin: 0 auto;
  padding: 96px 48px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.cover-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--red);
  text-transform: uppercase;
  margin-bottom: 20px;
}
.cover-title {
  font-size: 42px;
  font-weight: 800;
  color: var(--white);
  line-height: 1.2;
  margin-bottom: 20px;
}
.cover-title span { color: #F0A0A0; }
.cover-desc {
  font-size: 15px;
  color: #9CA3AF;
  line-height: 1.8;
  margin-bottom: 32px;
}
.cover-tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.cover-tag {
  padding: 5px 14px;
  border: 1px solid #374151;
  border-radius: 20px;
  font-size: 11px;
  color: #9CA3AF;
}
.cover-right {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.cover-stat {
  background: #1C1C1C;
  border: 1px solid #2D2D2D;
  border-radius: 10px;
  padding: 20px 24px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.cover-stat-icon {
  width: 40px;
  height: 40px;
  background: #2D2D2D;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}
.cover-stat-label { font-size: 11px; color: #6B7280; margin-bottom: 3px; }
.cover-stat-val { font-size: 14px; font-weight: 600; color: var(--white); }

/* ── 한줄 요약 띠 ── */
.summary-band {
  background: var(--red-bg);
  border-top: 1px solid #E0B0B0;
  border-bottom: 1px solid #E0B0B0;
}
.summary-band-inner {
  max-width: 1080px;
  margin: 0 auto;
  padding: 28px 48px;
  display: flex;
  align-items: flex-start;
  gap: 24px;
}
.summary-icon {
  font-size: 24px;
  flex-shrink: 0;
  margin-top: 2px;
}
.summary-text {
  font-size: 16px;
  font-weight: 600;
  color: var(--black);
  line-height: 1.65;
}
.summary-text strong { color: var(--red); }

/* ── compare grid ── */
.compare-grid {
  display: grid;
  grid-template-columns: 1fr 48px 1fr;
  gap: 0;
  align-items: stretch;
  margin-bottom: 56px;
}
.compare-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  color: var(--red);
  font-weight: 700;
}
.compare-box {
  border-radius: 10px;
  padding: 28px 32px;
}
.compare-box.problem {
  background: var(--gray-light);
  border: 1px solid var(--gray-mid);
}
.compare-box.solution {
  background: var(--red-bg);
  border: 1px solid #E0B0B0;
  border-left: 4px solid var(--red);
}
.compare-tag {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 10px;
}
.compare-box.solution .compare-tag { color: var(--red); }
.compare-head {
  font-size: 20px;
  font-weight: 700;
  color: var(--black);
  margin-bottom: 10px;
  line-height: 1.35;
}
.compare-desc {
  font-size: 13px;
  color: var(--gray);
  line-height: 1.8;
  margin-bottom: 16px;
}
.compare-chips {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}
.chip {
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
}
.chip.gray { background: var(--white); color: var(--gray); border: 1px solid var(--gray-mid); }
.chip.red { background: var(--red); color: var(--white); }

/* ── 문제 목록 (엑셀 한계) ── */
.problem-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 16px;
}
.problem-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 13px;
  color: var(--gray-dark);
  line-height: 1.6;
}
.problem-num {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--gray-mid);
  color: var(--gray);
  font-size: 10px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}

/* ── 기능 카드 (모달 소개) ── */
.feature-card {
  border: 1px solid var(--gray-mid);
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 32px;
}
.feature-header {
  background: var(--gray-light);
  padding: 20px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--gray-mid);
}
.feature-num {
  font-size: 11px;
  font-weight: 700;
  color: var(--red);
  letter-spacing: 0.1em;
  margin-bottom: 4px;
}
.feature-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--black);
}
.feature-subtitle {
  font-size: 12px;
  color: var(--gray);
  margin-top: 3px;
}
.feature-badge {
  padding: 6px 16px;
  background: var(--red);
  color: var(--white);
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
  white-space: nowrap;
}
.feature-body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}
.feature-col {
  padding: 28px 32px;
}
.feature-col + .feature-col {
  border-left: 1px solid var(--gray-mid);
}
.feature-col-title {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--gray-mid);
}

/* ── KPI 미니 바 ── */
.kpi-mini-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 0;
}
.kpi-mini {
  background: var(--white);
  border: 1px solid var(--gray-mid);
  border-radius: 8px;
  padding: 10px 14px;
}
.kpi-mini-label {
  font-size: 11px;
  color: var(--gray);
  margin-bottom: 4px;
}
.kpi-mini-val {
  font-size: 18px;
  font-weight: 800;
  color: var(--black);
  letter-spacing: -0.03em;
}
.kpi-mini-val.accent { color: var(--red); }

/* ── 탭 미리보기 ── */
.tab-preview {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.tab-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 1px solid #F9FAFB;
}
.tab-item:last-child { border-bottom: none; }
.tab-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--red);
  flex-shrink: 0;
  margin-top: 6px;
}
.tab-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--black);
  margin-bottom: 2px;
}
.tab-desc {
  font-size: 12px;
  color: var(--gray);
  line-height: 1.55;
}

/* ── 워크플로우 ── */
.workflow-steps {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.wf-step {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid #F9FAFB;
}
.wf-step:last-child { border-bottom: none; }
.wf-circle {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--gray-light);
  border: 1px solid var(--gray-mid);
  color: var(--gray);
  font-size: 10px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}
.wf-circle.accent {
  background: var(--red);
  color: var(--white);
  border-color: var(--red);
}
.wf-content { flex: 1; }
.wf-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--black);
  margin-bottom: 2px;
}
.wf-desc { font-size: 12px; color: var(--gray); line-height: 1.5; }

/* ── feature footer ── */
.feature-footer {
  background: #FAFAFA;
  border-top: 1px solid var(--gray-mid);
  padding: 16px 32px;
  display: flex;
  gap: 24px;
  flex-wrap: wrap;
}
.key-point {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 12px;
  color: var(--black);
  flex: 1;
  min-width: 200px;
}
.kp-bar {
  width: 3px;
  min-height: 32px;
  background: var(--red);
  border-radius: 2px;
  flex-shrink: 0;
  align-self: stretch;
}
.kp-text { line-height: 1.55; }
.kp-text strong { font-weight: 700; }

/* ── 질문 예시 ── */
.qa-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 0;
}
.qa-card {
  border: 1px solid var(--gray-mid);
  border-radius: 10px;
  padding: 20px 22px;
  background: var(--white);
}
.qa-feature {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 10px;
}
.qa-q {
  font-size: 13px;
  font-weight: 600;
  color: var(--black);
  line-height: 1.55;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--gray-mid);
}
.qa-a {
  font-size: 12px;
  color: var(--gray);
  line-height: 1.6;
}
.qa-a strong { color: var(--red); font-weight: 700; }

/* ── 흐름 연결 프로세스 ── */
.flow-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr) 0 repeat(1, 1fr);
  gap: 0;
  position: relative;
  margin-bottom: 48px;
}
.flow-steps {
  display: flex;
  align-items: flex-start;
  gap: 0;
  position: relative;
  margin-bottom: 48px;
}
.flow-steps::before {
  content: '';
  position: absolute;
  top: 28px;
  left: 10%;
  width: 80%;
  height: 1px;
  background: var(--gray-mid);
  z-index: 0;
}
.flow-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  text-align: center;
  position: relative;
  z-index: 1;
}
.flow-circle {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  position: relative;
  background: var(--white);
  border: 1.5px solid var(--gray-mid);
}
.flow-circle.accent {
  background: var(--red);
  border-color: var(--red);
}
.flow-num {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 18px;
  height: 18px;
  background: var(--red);
  color: var(--white);
  border-radius: 50%;
  font-size: 9px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.flow-circle.accent .flow-num { background: var(--black); }
.flow-name {
  font-size: 12px;
  font-weight: 700;
  color: var(--black);
  line-height: 1.35;
}
.flow-desc {
  font-size: 11px;
  color: var(--gray);
  line-height: 1.5;
}
.flow-tag {
  font-size: 10px;
  font-weight: 700;
  padding: 2px 10px;
  border-radius: 10px;
}
.flow-tag-main { background: var(--red-bg); color: var(--red); border: 1px solid #E0B0B0; }
.flow-tag-sub { background: var(--gray-light); color: var(--gray-dark); border: 1px solid var(--gray-mid); }

/* ── divider (검정 띠) ── */
.divider-section {
  background: var(--black);
  padding: 56px 0;
}
.divider-inner {
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  flex-wrap: wrap;
}
.divider-msg {
  font-size: 22px;
  font-weight: 700;
  color: var(--white);
  line-height: 1.4;
  max-width: 620px;
}
.divider-msg span { color: #F0A0A0; }
.divider-sub { font-size: 12px; color: #6B7280; margin-top: 6px; }

/* ── Before/After 표 ── */
.compare-table-wrap { margin-bottom: 56px; }
.compare-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
.compare-table th {
  padding: 12px 20px;
  text-align: left;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray);
  background: var(--gray-light);
  border-bottom: 1px solid var(--gray-mid);
}
.compare-table th:first-child { border-radius: 8px 0 0 0; }
.compare-table th:last-child { border-radius: 0 8px 0 0; }
.compare-table td {
  padding: 14px 20px;
  border-bottom: 1px solid var(--gray-mid);
  vertical-align: middle;
}
.compare-table tr:last-child td { border-bottom: none; }
.compare-table .item { font-weight: 600; color: var(--black); }
.compare-table .before { color: var(--gray); }
.compare-table .after { color: var(--red); font-weight: 600; }

/* ── 로드맵 ── */
.roadmap-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
.rm-card {
  border: 1px solid var(--gray-mid);
  border-radius: 10px;
  padding: 20px 22px;
  position: relative;
}
.rm-card.current {
  background: var(--red-bg);
  border-color: #E0B0B0;
}
.rm-phase {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--gray);
  margin-bottom: 6px;
}
.rm-card.current .rm-phase { color: var(--red); }
.rm-title { font-size: 14px; font-weight: 700; color: var(--black); margin-bottom: 8px; }
.rm-desc { font-size: 11.5px; color: var(--gray); line-height: 1.65; }
.rm-badge {
  display: inline-block;
  margin-top: 12px;
  padding: 3px 10px;
  border-radius: 10px;
  font-size: 10px;
  font-weight: 700;
}
.rm-badge.done { background: var(--red); color: var(--white); }
.rm-badge.next { background: var(--gray-mid); color: var(--gray); }

/* ── footer ── */
.footer {
  background: var(--black);
  padding: 32px 0;
  text-align: center;
}
.footer-text { font-size: 12px; color: #6B7280; }
.footer-text span { color: #F0A0A0; }

/* ── 반응형 ── */
@media (max-width: 768px) {
  .section { padding: 48px 24px; }
  .cover-inner { grid-template-columns: 1fr; gap: 40px; }
  .compare-grid { grid-template-columns: 1fr; }
  .compare-arrow { transform: rotate(90deg); }
  .feature-body { grid-template-columns: 1fr; }
  .feature-col + .feature-col { border-left: none; border-top: 1px solid var(--gray-mid); }
  .qa-grid { grid-template-columns: 1fr; }
  .roadmap-grid { grid-template-columns: 1fr 1fr; }
  .flow-steps::before { display: none; }
}

@media print {
  body { background: white; }
  .cover { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  .divider-section { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
}
</style>
</head>
